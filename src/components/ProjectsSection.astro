---
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
const base = import.meta.env.BASE_URL;
const mainProjects = projects.filter(p => p.isMain);
const supportingProjects = projects.filter(p => !p.isMain);
---

<section class="section" id="projects" style="background: var(--c-bg);">
  <div class="container">
    <p class="section-label">PROJECTS</p>
    <h2 class="section-title">6개 프로젝트</h2>
    <p class="section-desc">
      데이터 분석, 콘텐츠 기획, AI 자동화, 팀 PM, 브랜드 MD — 다양한 각도에서
      문제를 구조화하고 실행했습니다.
    </p>

    <div class="projects-divider"></div>

    <p class="group-label">MAIN CASE STUDIES</p>
    <div class="grid grid--main">
      {mainProjects.map(p => <ProjectCard project={p} base={base} />)}
    </div>

    <p class="group-label" style="margin-top: 2.5rem;">SUPPORTING EXPERIENCE</p>
    <div class="grid grid--supporting">
      {supportingProjects.map(p => <ProjectCard project={p} base={base} />)}
    </div>
  </div>
</section>

<style>
  .projects-divider {
    height: 1px;
    background: var(--c-hairline);
    margin: 2.5rem 0 1.5rem;
  }

  .group-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    color: var(--c-mute);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .grid {
    display: grid;
    gap: 1px;
    background: var(--c-hairline);
    border: 1px solid var(--c-hairline);
  }

  .grid--main {
    grid-template-columns: repeat(3, 1fr);
  }

  .grid--supporting {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (max-width: 760px) {
    .grid--main {
      grid-template-columns: 1fr;
    }
    .grid--supporting {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 500px) and (max-width: 760px) {
    .grid--supporting {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
