---
import type { Project } from '../data/projects';
interface Props {
  project: Project;
  base: string;
}
const { project, base } = Astro.props;
---

<a href={`${base}/projects/${project.slug}`} class={`card ${project.isMain ? 'card--main' : 'card--supporting'}`}>
  <div class="card-top">
    <span class="card-category">{project.category}</span>
    <span class="card-period">{project.period}</span>
  </div>
  <h3 class="card-title">{project.title}</h3>
  <p class="card-subtitle">{project.subtitle}</p>
  <div class="card-highlight">
    <span class="highlight-badge">{project.highlight}</span>
  </div>
  <div class="card-tags">
    {project.tags.slice(0, 4).map(tag => (
      <span class="chip">{tag}</span>
    ))}
  </div>
  <div class="card-arrow">→</div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--c-canvas);
    border: 1px solid var(--c-hairline);
    padding: 1.5rem;
    transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
    cursor: pointer;
    position: relative;
  }

  .card:hover {
    border-color: var(--c-sky-line);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .card--supporting {
    background: var(--c-surface);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.875rem;
  }

  .card-category {
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    color: var(--c-sky);
    text-transform: uppercase;
  }

  .card-period {
    font-size: 0.6875rem;
    color: var(--c-mute);
    font-variant-numeric: tabular-nums;
  }

  .card-title {
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--c-ink);
    line-height: 1.35;
    margin-bottom: 0.5rem;
  }

  .card-subtitle {
    font-size: 0.8125rem;
    color: var(--c-body);
    line-height: 1.5;
    margin-bottom: 1rem;
    flex: 1;
  }

  .card-highlight {
    margin-bottom: 1rem;
  }

  .highlight-badge {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--c-sky-deep);
    background: var(--c-sky-soft);
    border: 1px solid var(--c-sky-line);
    border-radius: 9999px;
    padding: 0.2em 0.75em;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1rem;
  }

  .card-arrow {
    font-size: 0.875rem;
    color: var(--c-sky);
    align-self: flex-end;
    transition: transform var(--dur) var(--ease);
  }

  .card:hover .card-arrow {
    transform: translateX(3px);
  }
</style>
