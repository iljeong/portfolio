---
const expertise = [
  {
    area: 'PROBLEM DEFINITION',
    desc: '사용자 데이터와 리뷰에서 핵심 문제를 구조화하고 정의한다.',
    examples: ['Gcar 리뷰 37,923건 분석', '고객 여정 기반 이탈 구조 규명'],
  },
  {
    area: 'PRODUCT PLANNING',
    desc: '기획 → 실행 → 성과 전 과정을 직접 운영한다.',
    examples: ['패스트캠퍼스 신규 강의 6개 출시', '살미달라 3시즌 MD 운영'],
  },
  {
    area: 'CONTENT PRODUCTION',
    desc: '기획부터 영상·출판까지 멀티포맷 콘텐츠를 직접 제작한다.',
    examples: ['유튜브 50편+ 기획·편집', '출판물 3권 InDesign 제작'],
  },
  {
    area: 'AI OPERATIONS',
    desc: 'AI 도구로 반복 업무를 파이프라인으로 전환한다.',
    examples: ['Claude AI + Figma MCP 파이프라인', '제작 시간 83% 단축'],
  },
];

const tools = [
  { name: 'Python · SQL', level: 2 },
  { name: 'Figma', level: 3 },
  { name: 'Notion', level: 4 },
  { name: 'Claude AI', level: 4 },
  { name: 'Premiere Pro', level: 3 },
  { name: 'Photoshop', level: 3 },
  { name: 'InDesign', level: 2 },
  { name: 'Google Sheets', level: 3 },
];
---

<section class="section" id="skills" style="background: var(--c-canvas);">
  <div class="container">
    <p class="section-label">SKILLS</p>
    <h2 class="section-title">역량</h2>

    <div class="skills-grid">
      <!-- Left: Expertise -->
      <div class="expertise-list">
        {expertise.map((e, i) => (
          <div class="exp-item">
            <div class="exp-header">
              <span class="exp-num">0{i + 1}</span>
              <span class="exp-area">{e.area}</span>
            </div>
            <p class="exp-desc">{e.desc}</p>
            <ul class="exp-examples">
              {e.examples.map(ex => <li>{ex}</li>)}
            </ul>
          </div>
        ))}
      </div>

      <!-- Right: Tools -->
      <div class="tools-col">
        <p class="tools-label">TOOLS</p>
        <div class="tools-list">
          {tools.map(t => (
            <div class="tool-row">
              <span class="tool-name">{t.name}</span>
              <div class="tool-bar">
                {Array.from({ length: 5 }).map((_, i) => (
                  <span class={`bar-dot ${i < t.level ? 'bar-dot--on' : ''}`} />
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 4rem;
    margin-top: 2rem;
  }

  /* Expertise */
  .expertise-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--c-hairline);
  }

  .exp-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--c-hairline);
  }

  .exp-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .exp-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--c-mute);
    letter-spacing: -0.02em;
    line-height: 1;
    min-width: 2rem;
  }

  .exp-area {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--c-ink);
  }

  .exp-desc {
    font-size: 0.875rem;
    color: var(--c-body);
    margin-bottom: 0.5rem;
    line-height: 1.6;
    padding-left: 2.75rem;
  }

  .exp-examples {
    list-style: none;
    padding-left: 2.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .exp-examples li {
    font-size: 0.8125rem;
    color: var(--c-mute);
    position: relative;
    padding-left: 0.875rem;
  }

  .exp-examples li::before {
    content: '·';
    position: absolute;
    left: 0;
  }

  /* Tools */
  .tools-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    color: var(--c-mute);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .tools-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--c-hairline);
  }

  .tool-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--c-hairline);
  }

  .tool-name {
    font-size: 0.875rem;
    color: var(--c-body);
  }

  .tool-bar {
    display: flex;
    gap: 3px;
  }

  .bar-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--c-hairline);
  }

  .bar-dot--on {
    background: var(--c-ink);
  }

  @media (max-width: 760px) {
    .skills-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
