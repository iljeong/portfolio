---
type Step = { label: string; desc?: string };
interface Props {
  flow: {
    title: string;
    layout: 'chain' | 'roadmap';
    tone?: 'negative' | 'process';
    caption?: string;
    steps: Step[];
    note?: string;
  };
}
const { flow } = Astro.props;
const tone = flow.tone ?? 'default';
---

{flow.layout === 'chain' ? (
  <div class="flow flow--chain" data-tone={tone}>
    {flow.steps.map((s, i) => (
      <>
        <div class="flow-node">
          <span class="flow-node-label">{s.label}</span>
          {s.desc && <span class="flow-node-desc">{s.desc}</span>}
        </div>
        {i < flow.steps.length - 1 && <span class="flow-arrow" aria-hidden="true">→</span>}
      </>
    ))}
  </div>
) : (
  <ol class="flow flow--roadmap" role="list">
    {flow.steps.map((s, i) => (
      <li class="flow-stop">
        <span class="flow-stop-num">{String(i + 1).padStart(2, '0')}</span>
        <div class="flow-stop-body">
          <p class="flow-stop-label">{s.label}</p>
          {s.desc && <p class="flow-stop-desc">{s.desc}</p>}
        </div>
      </li>
    ))}
  </ol>
)}

{flow.note && <p class="flow-note">{flow.note}</p>}

<style>
  /* ── Chain (horizontal) ───────────────────────── */
  .flow--chain {
    display: flex;
    align-items: stretch;
    gap: 0;
  }

  .flow-node {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    justify-content: center;
    text-align: center;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    padding: 0.9rem 0.65rem;
  }

  .flow-node-label {
    font-size: var(--text-base);          /* 14px */
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    line-height: 1.3;
    word-break: keep-all;
  }

  .flow-node-desc {
    font-size: var(--text-xs);            /* 11px */
    color: var(--ink-3);
    line-height: 1.45;
    word-break: keep-all;
  }

  .flow-arrow {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    padding: 0 0.45rem;
    color: var(--ink-4);
    font-size: var(--text-lg);
  }

  /* Terminal-node emphasis */
  .flow--chain[data-tone='negative'] .flow-node:last-of-type {
    background: var(--ink);
    border-color: var(--ink);
  }
  .flow--chain[data-tone='negative'] .flow-node:last-of-type .flow-node-label { color: #fff; }
  .flow--chain[data-tone='negative'] .flow-node:last-of-type .flow-node-desc { color: rgba(255, 255, 255, 0.6); }

  .flow--chain[data-tone='process'] .flow-node:last-of-type {
    background: var(--accent);
    border-color: var(--accent);
  }
  .flow--chain[data-tone='process'] .flow-node:last-of-type .flow-node-label { color: #fff; }
  .flow--chain[data-tone='process'] .flow-node:last-of-type .flow-node-desc { color: rgba(255, 255, 255, 0.7); }

  @media (max-width: 640px) {
    .flow--chain { flex-direction: column; }
    .flow-node { width: 100%; }
    .flow-arrow { transform: rotate(90deg); padding: 0.15rem 0; }
  }

  /* ── Roadmap (vertical) ───────────────────────── */
  .flow--roadmap { list-style: none; }

  .flow-stop {
    position: relative;
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0 1rem;
    padding-bottom: 1.6rem;
  }
  .flow-stop:last-child { padding-bottom: 0; }

  /* connector line */
  .flow-stop:not(:last-child)::before {
    content: '';
    position: absolute;
    left: 0.9375rem;          /* center of the 2rem num */
    top: 2.1rem;
    bottom: -0.1rem;
    width: 2px;
    background: var(--line);
  }

  .flow-stop-num {
    position: relative;
    z-index: 1;
    width: 2rem;
    height: 2rem;
    border-radius: var(--r-full);
    background: var(--accent-bg);
    color: var(--accent);
    font-size: var(--text-xs);
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .flow-stop-label {
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
    padding-top: 0.2rem;
  }

  .flow-stop-desc {
    font-size: var(--text-caption);
    color: var(--ink-3);
    line-height: 1.65;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  /* ── Note ─────────────────────────────────────── */
  .flow-note {
    margin-top: 1.1rem;
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-bg);
    border-radius: var(--r-sm);
    padding: 0.6rem 0.9rem;
    display: inline-block;
    word-break: keep-all;
  }
</style>
