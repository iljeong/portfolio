---
import { projects } from '../data/projects';
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const asset = (s: string) => `${basePath}${s.replace(/^\/+/, '')}`;

// 강약: 대표 3개(직무중립 — 일하는 방식이 드러나는 프로젝트)는 산출물 이미지 카드로,
// 나머지는 컴팩트 리스트로.
const featuredSlugs = ['fastcampus', 'gcar-voc', 'pullsize'];
const restSlugs = ['salmidalla', 'ai-content-automation', 'areun-sai'];
const featured = featuredSlugs.map(slug => projects.find(p => p.slug === slug)!);
const rest = restSlugs.map(slug => projects.find(p => p.slug === slug)!);
---

<section id="work" class="work-section">
  <div class="container">

    <div class="work-head">
      <h2 class="label">Selected Work</h2>
      <span class="label work-range">2021 — 현재</span>
    </div>

    <!-- 대표 프로젝트: 산출물 이미지 + 수치 오버레이 카드 -->
    <div class="feat-grid">
      {featured.map((p, i) => (
        <a
          href={`${base}/projects/${p.slug}`}
          class="feat-card"
          data-reveal
          style={`--reveal-delay:${i * 80}ms`}
        >
          <div class="feat-media">
            {p.cover!.art ? (
              <div class={`feat-code-cover feat-code-cover--${p.cover!.art}`} aria-hidden="true">
                {p.cover!.art === 'modules' ? (
                  <svg class="feat-motif feat-motif--modules" viewBox="0 0 360 220" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <g stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="24" y="24" width="92" height="72" rx="16" />
                      <rect x="134" y="24" width="92" height="72" rx="16" />
                      <rect x="244" y="24" width="92" height="72" rx="16" />
                      <rect x="24" y="124" width="92" height="72" rx="16" />
                      <rect x="134" y="124" width="92" height="72" rx="16" />
                      <rect x="244" y="124" width="92" height="72" rx="16" />
                      <path d="M48 54H82" />
                      <path d="M158 54H192" />
                      <path d="M268 54H302" />
                      <path d="M48 154H82" />
                      <path d="M158 154H192" />
                      <path d="M268 154H302" />
                    </g>
                  </svg>
                ) : (
                  <svg class="feat-motif feat-motif--data" viewBox="0 0 360 220" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <g fill="currentColor">
                      <rect x="44" y="132" width="22" height="54" rx="8" />
                      <rect x="82" y="112" width="22" height="74" rx="8" />
                      <rect x="120" y="148" width="22" height="38" rx="8" />
                      <rect x="158" y="82" width="22" height="104" rx="8" />
                      <rect x="196" y="102" width="22" height="84" rx="8" />
                      <rect x="234" y="58" width="22" height="128" rx="8" />
                      <rect x="272" y="126" width="22" height="60" rx="8" />
                    </g>
                    <path d="M36 186H318" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                  </svg>
                )}
              </div>
            ) : (
              <img
                src={asset(p.cover!.src!)}
                alt={`${p.name} 산출물`}
                loading="lazy"
                style={`object-position:${p.cover!.pos ?? 'center'}`}
              />
            )}
            <div class="feat-scrim"></div>
            <div class="feat-overlay">
              {p.cover!.badge && <span class="feat-badge">{p.cover!.badge}</span>}
              <span class="feat-stat">{p.cover!.stat}</span>
              <span class="feat-stat-label">{p.cover!.statLabel}</span>
            </div>
          </div>
          <div class="feat-foot">
            <div class="feat-foot-text">
              <span class="feat-name">{p.name}</span>
              <span class="feat-cat">{p.category}</span>
            </div>
            <span class="feat-arrow" aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>

    <!-- 그 외 작업: 컴팩트 리스트 -->
    <div class="more-head">
      <h3 class="more-label">그 외 작업</h3>
    </div>
    <ul class="work-list" role="list">
      {rest.map((p, i) => (
        <li class="work-item" data-slug={p.slug} data-reveal style={`--reveal-delay:${i * 55}ms`}>
          <a href={`${base}/projects/${p.slug}`} class="work-link">
            <span class="work-num">{String(i + 4).padStart(2, '0')}</span>
            <span class="work-main">
              <span class="work-name">{p.name}</span>
              <span class="work-meta-row">
                <span class="work-cat">{p.category.split('·')[0].trim()}</span>
                <span class="work-sep">·</span>
                <span class="work-kpi">{p.highlight}</span>
                <span class="work-sep work-period-sep">·</span>
                <span class="work-period-meta">{p.period.replace(' — ', '–')}</span>
              </span>
            </span>
            <span class="work-period">{p.period.replace(' — ', '–')}</span>
            <span class="work-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .work-section { padding: 3rem 0 5rem; scroll-margin-top: 4rem; }

  /* Header row */
  .work-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .work-range { color: var(--ink-3); }

  /* ── Featured cover cards ── */
  .feat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-bottom: 3.25rem;
  }

  .feat-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--surface);
    transition:
      box-shadow var(--dur) var(--ease),
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }

  .feat-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: var(--line-strong);
    transform: translateY(-3px);
  }

  .feat-media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--surface);
  }

  .feat-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-slow) var(--ease);
  }

  .feat-card:hover .feat-media img { transform: scale(1.04); }

  .feat-code-cover {
    position: absolute;
    inset: 0;
    display: block;
    overflow: hidden;
    background:
      radial-gradient(circle at 18% 16%, rgba(255, 255, 255, 0.18), transparent 30%),
      radial-gradient(circle at 84% 12%, rgba(43, 92, 230, 0.26), transparent 34%),
      linear-gradient(135deg, var(--accent) 0%, #151a28 54%, var(--ink) 100%);
  }

  .feat-code-cover::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg, rgba(255, 255, 255, 0.08), transparent 42%),
      radial-gradient(circle at 72% 76%, rgba(255, 255, 255, 0.1), transparent 38%);
  }

  .feat-code-cover--data {
    background:
      radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.14), transparent 28%),
      radial-gradient(circle at 82% 18%, rgba(43, 92, 230, 0.24), transparent 34%),
      linear-gradient(135deg, #1f4fba 0%, #171717 52%, var(--ink) 100%);
  }

  .feat-motif {
    position: absolute;
    left: 9%;
    top: 12%;
    width: 82%;
    height: 72%;
    color: #fff;
    opacity: 0.14;
    transform-origin: center;
    transition:
      transform var(--dur-slow) var(--ease),
      opacity var(--dur-slow) var(--ease);
  }

  .feat-motif--data {
    left: 10%;
    top: 13%;
    width: 80%;
    height: 70%;
    opacity: 0.13;
  }

  .feat-card:hover .feat-motif {
    transform: scale(1.025);
    opacity: 0.16;
  }

  /* Restrained gradient — legibility without an "ad" look */
  .feat-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(0, 0, 0, 0.32) 32%,
      rgba(0, 0, 0, 0) 60%
    );
  }

  .feat-overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 1.125rem 1.125rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .feat-badge {
    align-self: flex-start;
    margin-bottom: 0.5rem;
    padding: 0.28rem 0.6rem;
    border-radius: var(--r-sm);
    background: rgba(15, 15, 20, 0.62);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    color: #fff;
    font-size: var(--text-2xs);
    font-weight: 700;
    letter-spacing: 0.04em;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
  }

  .feat-stat {
    font-family: var(--font);
    font-size: clamp(1.5rem, 2.4vw, 1.875rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    line-height: 1.05;
  }

  .feat-stat-label {
    font-size: var(--text-sm);      /* 12px */
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.4;
    word-break: keep-all;
  }

  .feat-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.875rem 1.125rem;
  }

  .feat-foot-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .feat-name {
    font-size: var(--text-body);    /* 15px */
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .feat-card:hover .feat-name { color: var(--accent); }

  .feat-cat {
    font-size: var(--text-sm);      /* 12px */
    color: var(--ink-3);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .feat-arrow {
    font-size: var(--text-md);
    color: var(--ink-4);
    flex-shrink: 0;
    transition:
      transform var(--dur-fast) var(--ease-spring),
      color var(--dur-fast) var(--ease);
  }

  .feat-card:hover .feat-arrow {
    transform: translate(2px, -2px);
    color: var(--accent);
  }

  @media (max-width: 760px) {
    .feat-grid {
      grid-template-columns: 1fr;
      gap: 0.625rem;
    }
    .feat-media { aspect-ratio: 16 / 10; }
  }

  /* ── "그 외" compact list ── */
  .more-head {
    margin-bottom: 0.625rem;
    padding: 0 0.5rem;
  }

  .more-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    list-style: none;
  }

  .work-item {
    background: var(--surface);
    transition: background var(--dur-fast) var(--ease);
    border-radius: var(--r-lg);
  }

  .work-item:hover {
    background: var(--accent-bg);
  }

  .work-link {
    display: grid;
    grid-template-columns: 2.25rem 1fr auto auto;
    align-items: center;
    gap: 0.875rem;
    padding: 1.125rem 0.75rem;
  }

  .work-num {
    font-family: var(--font);
    font-size: var(--text-base);    /* 14px */
    font-weight: 600;
    color: var(--ink-4);
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }

  .work-main {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .work-name {
    font-size: var(--text-subhead);  /* 17px */
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink-2);
    transition: color var(--dur-fast) var(--ease);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .work-item:hover .work-name { color: var(--accent); }

  .work-meta-row {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-caption);  /* 13px */
    color: var(--ink-3);
    min-width: 0;
  }

  .work-sep  { opacity: 0.45; }

  .work-cat {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .work-kpi {
    color: var(--accent);
    font-weight: 500;
    font-size: var(--text-sm);       /* 12px */
    white-space: nowrap;
  }

  .work-period {
    font-size: var(--text-xs);       /* 11px */
    color: var(--ink-3);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.01em;
  }

  .work-arrow {
    font-size: var(--text-md);
    color: var(--ink-4);
    transition:
      transform  var(--dur-fast) var(--ease-spring),
      color      var(--dur-fast) var(--ease);
  }

  .work-item:hover .work-arrow {
    transform: translate(2px, -2px);
    color: var(--accent);
  }

  .work-period-sep,
  .work-period-meta { display: none; }

  @media (max-width: 860px) {
    .work-name {
      white-space: normal;
      overflow: visible;
      word-break: keep-all;
      overflow-wrap: anywhere;
    }
    .work-link {
      grid-template-columns: 2rem 1fr auto;
      gap: 0.75rem;
      padding-left: 0.25rem;
      padding-right: 0.25rem;
    }
    .work-period { display: none; }
    .work-meta-row {
      flex-wrap: wrap;
      row-gap: 0.15rem;
      line-height: 1.45;
    }
    .work-cat {
      max-width: 100%;
    }
    .work-period-sep { display: none; }
    .work-period-meta {
      display: block;
      flex-basis: 100%;
      color: var(--ink-4);
      font-size: var(--text-xs);
      line-height: 1.3;
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.01em;
    }
  }
</style>
