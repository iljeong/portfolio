---
import { projects } from '../data/projects';
const base = import.meta.env.BASE_URL;

const previewStyles: Record<string, { bg: string; accent: string }> = {
  'gcar-voc':   { bg: '#10203E', accent: '#93B8F5' },
  'fastcampus': { bg: '#3B1506', accent: '#F5A86E' },
  'ai-content-automation': { bg: '#0C0F1F', accent: '#A5B4FC' },
  'pullsize':   { bg: '#0E2A2F', accent: '#7DD3C7' },
  'areun-sai':  { bg: '#1A2613', accent: '#A3D48A' },
  'salmidalla': { bg: '#231108', accent: '#E8C9A8' },
};
---

<section id="work" class="work-section">
  <div class="container">

    <div class="work-head">
      <span class="label">Work</span>
      <span class="label work-range">2021 — 현재</span>
    </div>

    <hr class="line work-rule" />

    <div class="work-layout">

      <!-- Project list -->
      <ul class="work-list" role="list">
        {projects.map((p, i) => (
          <li class="work-item" data-slug={p.slug}
              data-title={p.title}
              data-subtitle={p.subtitle}
              data-category={p.category}
              data-period={p.period}
              data-highlight={p.highlight}
              data-tags={JSON.stringify(p.tags)}
              data-links={JSON.stringify(p.links ?? [])}>
            <a href={`${base}/projects/${p.slug}`} class="work-link">
              <span class="work-num">0{i + 1}</span>
              <span class="work-main">
                <span class="work-name">{p.name}</span>
                <span class="work-meta-row">
                  <span class="work-cat">{p.category.split('·')[0].trim()}</span>
                  <span class="work-sep">·</span>
                  <span class="work-kpi">{p.highlight}</span>
                  <span class="work-sep work-period-sep">·</span>
                  <span class="work-period-meta">{p.period.replace(' — ', '–')}</span>
                </span>
              </span>
              <span class="work-period">{p.period.replace(' — ', '–')}</span>
              <span class="work-arrow" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ul>

      <!-- Hover preview panel (desktop only) -->
      <aside class="work-preview" aria-hidden="true">
        <div class="preview-idle">
          <span>hover to preview</span>
        </div>
        {projects.map(p => {
          const s = previewStyles[p.slug] ?? { bg: '#1A1A1A', accent: '#E0E0E0' };
          return (
            <div class="preview-card" data-for={p.slug} style={`background:${s.bg}`}>
              <p class="pc-cat" style={`color:${s.accent}`}>{p.category}</p>
              <p class="pc-kpi" style={`color:${s.accent}`}>{p.highlight}</p>
              <p class="pc-sub" style={`color:${s.accent};opacity:.65`}>{p.subtitle}</p>
              <div class="pc-chips">
                {p.tags.slice(0, 3).map(t => (
                  <span class="pc-chip" style={`border-color:${s.accent}30;color:${s.accent};opacity:.8`}>
                    {t}
                  </span>
                ))}
              </div>
            </div>
          );
        })}
      </aside>

    </div>
  </div>
<!-- Modal -->
<div class="modal-overlay" id="work-modal" role="dialog" aria-modal="true">
  <div class="modal-box">
    <button class="modal-close" aria-label="닫기">✕</button>
    <div class="modal-inner">
      <p class="modal-meta">
        <span class="label label--accent" id="modal-cat"></span>
        <span class="modal-dot">·</span>
        <span class="label" id="modal-period"></span>
      </p>
      <h2 class="modal-title" id="modal-title"></h2>
      <p class="modal-sub" id="modal-sub"></p>
      <div class="modal-stat">
        <span class="modal-stat-num" id="modal-highlight"></span>
        <span class="modal-stat-label">핵심 성과</span>
      </div>
      <div class="modal-tags" id="modal-tags"></div>
      <div class="modal-actions" id="modal-actions">
        <a class="modal-cta" id="modal-cta" href="#">케이스 스터디 보기 →</a>
      </div>
    </div>
  </div>
</div>

<style>
  .work-section { padding: 3rem 0 5rem; }

  /* Header row */
  .work-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.125rem;
  }

  .work-range { color: var(--ink-4); }
  .work-rule  { margin-bottom: 0; }

  /* Grid: list + sticky preview */
  .work-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── List ── */
  .work-list { list-style: none; }

  .work-item {
    border-bottom: 1px solid var(--line);
    transition: background var(--dur-fast) var(--ease);
    border-radius: 0;
  }

  .work-item:hover {
    background: rgba(0, 0, 0, 0.025);   /* StyleSeed-style surface wash */
  }

  .work-link {
    display: grid;
    grid-template-columns: 2.25rem 1fr auto auto;
    align-items: center;
    gap: 0.875rem;
    padding: 1.25rem 0.5rem;
  }

  /* Number */
  .work-num {
    font-size: var(--text-xs);      /* 11px */
    font-weight: 500;
    color: var(--ink-4);
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  /* Name + meta */
  .work-main {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .work-name {
    font-size: var(--text-subhead);  /* 17px */
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    transition: color var(--dur-fast) var(--ease);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .work-item:hover .work-name { color: var(--accent); }

  .work-meta-row {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-caption);  /* 13px */
    color: var(--ink-3);
  }

  .work-sep  { opacity: 0.45; }

  .work-kpi {
    color: var(--accent);
    font-weight: 500;
    font-size: var(--text-sm);       /* 12px */
  }

  /* Period */
  .work-period {
    font-size: var(--text-xs);       /* 11px */
    color: var(--ink-3);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.01em;
  }

  /* Arrow */
  .work-arrow {
    font-size: var(--text-md);
    color: var(--ink-4);
    transition:
      transform  var(--dur-fast) var(--ease-spring),
      color      var(--dur-fast) var(--ease);
  }

  .work-item:hover .work-arrow {
    transform: translate(2px, -2px);
    color: var(--accent);
  }

  /* ── Preview panel ── */
  .work-preview {
    position: sticky;
    top: 5rem;
    height: 320px;
    border-radius: var(--r-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .preview-idle { display: none; }

  .preview-card {
    position: absolute;
    inset: 0;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0;
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity   var(--dur)      var(--ease-out),
      transform var(--dur)      var(--ease-out);
    pointer-events: none;
  }

  .preview-card.is-default {
    opacity: 0.52;
    transform: translateY(0);
  }

  .preview-card.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .pc-cat {
    font-size: var(--text-xs);   /* 11px */
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.875rem;
  }

  .pc-kpi {
    font-size: var(--text-4xl);  /* 36px */
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .pc-sub {
    font-size: var(--text-caption);  /* 13px */
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .pc-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .pc-chip {
    font-size: var(--text-2xs);   /* 10px */
    border: 1px solid;
    border-radius: var(--r-full);
    padding: 0.2em 0.6em;
    letter-spacing: 0.02em;
  }

  /* ── Modal ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.48);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur) var(--ease);
    backdrop-filter: blur(2px);
  }

  .modal-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .modal-box {
    background: var(--bg);
    border-radius: var(--r-xl);
    width: 100%;
    max-width: 560px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    transform: translateY(14px);
    transition: transform var(--dur) var(--ease-out);
    box-shadow: var(--shadow-xl);
  }

  .modal-overlay.is-open .modal-box {
    transform: translateY(0);
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--r-full);
    cursor: pointer;
    font-size: var(--text-sm);
    color: var(--ink-3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background var(--dur-fast) var(--ease),
      color      var(--dur-fast) var(--ease);
  }

  .modal-close:hover {
    background: var(--line);
    color: var(--ink);
  }

  .modal-inner { padding: 2rem; }

  .modal-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .modal-dot { color: var(--ink-4); font-size: var(--text-xs); }

  .modal-title {
    font-size: clamp(1.25rem, 3vw, 1.625rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.25;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .modal-sub {
    font-size: var(--text-body);
    color: var(--ink-2);
    line-height: 1.65;
    margin-bottom: 1.375rem;
  }

  .modal-stat {
    background: var(--ink);
    border-radius: var(--r-md);
    padding: 1.125rem 1.375rem;
    display: flex;
    align-items: baseline;
    gap: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .modal-stat-num {
    font-size: clamp(1.375rem, 4vw, 1.875rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #fff;
    line-height: 1;
  }

  .modal-stat-label {
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .modal-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1.375rem;
  }

  .modal-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
  }

  .modal-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1rem;
    background: var(--ink);
    color: #fff;
    border-radius: var(--r-sm);
    font-size: var(--text-caption);
    font-weight: 700;
    transition: opacity var(--dur-fast) var(--ease);
  }

  .modal-cta:hover { opacity: 0.78; }

  .modal-ext-link {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1rem;
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    font-size: var(--text-caption);
    font-weight: 500;
    color: var(--ink-2);
    transition:
      border-color var(--dur-fast) var(--ease),
      color        var(--dur-fast) var(--ease);
  }

  .modal-ext-link:hover {
    border-color: var(--ink-3);
    color: var(--ink);
  }

  /* period-meta: hidden on desktop, shown on mobile inside meta row */
  .work-period-sep,
  .work-period-meta { display: none; }

  /* Mobile: hide preview */
  @media (max-width: 860px) {
    .work-layout { grid-template-columns: 1fr; }
    .work-preview { display: none; }
    .work-link {
      grid-template-columns: 2rem 1fr auto;
      gap: 0.75rem;
      padding-left: 0.25rem;
      padding-right: 0.25rem;
    }
    .work-period { display: none; }
    .work-period-sep,
    .work-period-meta { display: inline; }
    .work-period-meta {
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.01em;
    }
  }
</style>

<script>
  const items     = document.querySelectorAll<HTMLElement>('.work-item');
  const cards     = document.querySelectorAll<HTMLElement>('.preview-card');
  const workLinks = document.querySelectorAll<HTMLAnchorElement>('.work-link');

  const modal      = document.getElementById('work-modal') as HTMLElement;
  const modalClose = modal.querySelector<HTMLElement>('.modal-close')!;

  const firstSlug = items[0]?.dataset.slug ?? '';

  // ── Preview panel ──────────────────────────────────
  function activate(slug: string) {
    cards.forEach(c => {
      c.classList.remove('is-default');
      c.classList.toggle('is-active', c.dataset.for === slug);
    });
  }

  function reset() {
    cards.forEach(c => {
      c.classList.remove('is-active');
      c.classList.toggle('is-default', c.dataset.for === firstSlug);
    });
  }

  reset();

  items.forEach(item => {
    item.addEventListener('mouseenter', () => activate(item.dataset.slug!));
    item.addEventListener('mouseleave', reset);
  });

  // ── Modal ──────────────────────────────────────────
  function openModal(item: HTMLElement, projectUrl: string) {
    (document.getElementById('modal-cat') as HTMLElement).textContent      = item.dataset.category ?? '';
    (document.getElementById('modal-period') as HTMLElement).textContent   = (item.dataset.period ?? '').replace(' — ', '–');
    (document.getElementById('modal-title') as HTMLElement).textContent    = item.dataset.title ?? '';
    (document.getElementById('modal-sub') as HTMLElement).textContent      = item.dataset.subtitle ?? '';
    (document.getElementById('modal-highlight') as HTMLElement).textContent = item.dataset.highlight ?? '';

    const tagsEl = document.getElementById('modal-tags') as HTMLElement;
    const tags: string[] = JSON.parse(item.dataset.tags ?? '[]');
    tagsEl.innerHTML = tags.map(t => `<span class="chip">${t}</span>`).join('');

    (document.getElementById('modal-cta') as HTMLAnchorElement).href = projectUrl;

    const actionsEl = document.getElementById('modal-actions') as HTMLElement;
    actionsEl.querySelectorAll('.modal-ext-link').forEach(el => el.remove());
    const links: { label: string; url: string }[] = JSON.parse(item.dataset.links ?? '[]');
    links.forEach(l => {
      const a = document.createElement('a');
      a.href = l.url;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.className = 'modal-ext-link';
      a.textContent = `${l.label} ↗`;
      actionsEl.appendChild(a);
    });

    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  workLinks.forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      openModal(link.closest<HTMLElement>('.work-item')!, link.href);
    });
  });

  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
