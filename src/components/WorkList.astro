---
import { projects } from '../data/projects';
const base = import.meta.env.BASE_URL;

const previewStyles: Record<string, { bg: string; accent: string }> = {
  'gcar-voc':   { bg: '#10203E', accent: '#93B8F5' },
  'fastcampus': { bg: '#3B1506', accent: '#F5A86E' },
  'pullsize':   { bg: '#0C0F1F', accent: '#A5B4FC' },
  'areun-sai':  { bg: '#1A2613', accent: '#A3D48A' },
  'salmidalla': { bg: '#231108', accent: '#E8C9A8' },
};
---

<section id="work" class="work-section">
  <div class="container">

    <div class="work-head">
      <span class="label">WORK</span>
      <span class="label work-range">2021 — 현재</span>
    </div>

    <hr class="line work-rule" />

    <div class="work-layout">

      <!-- Project list -->
      <ul class="work-list" role="list">
        {projects.map((p, i) => (
          <li class="work-item" data-slug={p.slug}>
            <a href={`${base}/projects/${p.slug}`} class="work-link">
              <span class="work-num">0{i + 1}</span>
              <span class="work-main">
                <span class="work-name">{p.name}</span>
                <span class="work-meta-row">
                  <span class="work-cat">{p.category.split('·')[0].trim()}</span>
                  <span class="work-dot">·</span>
                  <span class="work-highlight">{p.highlight}</span>
                </span>
              </span>
              <span class="work-period">{p.period.replace(' — ', '–')}</span>
              <span class="work-arrow">↗</span>
            </a>
          </li>
        ))}
      </ul>

      <!-- Hover preview panel (desktop only) -->
      <div class="work-preview" aria-hidden="true">
        <div class="preview-default">
          <p>프로젝트를<br />선택하세요</p>
        </div>
        {projects.map(p => {
          const s = previewStyles[p.slug] ?? { bg: '#1A1A1A', accent: '#E0E0E0' };
          return (
            <div
              class="preview-card"
              data-for={p.slug}
              style={`background:${s.bg}`}
            >
              <p class="pc-label" style={`color:${s.accent}`}>{p.category}</p>
              <p class="pc-metric" style={`color:${s.accent}`}>{p.highlight}</p>
              <p class="pc-subtitle" style={`color:${s.accent}; opacity:.7`}>{p.subtitle}</p>
              <div class="pc-tags">
                {p.tags.slice(0, 3).map(t => (
                  <span class="pc-tag" style={`border-color:${s.accent}33; color:${s.accent}; opacity:.8`}>{t}</span>
                ))}
              </div>
            </div>
          );
        })}
      </div>

    </div>
  </div>
</section>

<style>
  .work-section {
    padding: 5rem 0 6rem;
  }

  .work-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.25rem;
  }

  .work-range { color: var(--ink-4); }

  .work-rule { margin-bottom: 0; }

  /* Layout: list + sticky preview */
  .work-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }

  /* List */
  .work-list {
    list-style: none;
  }

  .work-item {
    border-bottom: 1px solid var(--line);
  }

  .work-link {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto auto;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 0;
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease);
  }

  .work-link:hover .work-name { color: var(--accent); }
  .work-link:hover .work-arrow { transform: translate(2px, -2px); color: var(--accent); }

  .work-num {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--ink-4);
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }

  .work-main {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .work-name {
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    transition: color var(--dur-fast) var(--ease);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .work-meta-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--ink-3);
  }

  .work-dot { opacity: 0.5; }

  .work-highlight {
    color: var(--accent);
    font-weight: 500;
  }

  .work-period {
    font-size: 0.75rem;
    color: var(--ink-3);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .work-arrow {
    font-size: 1rem;
    color: var(--ink-3);
    transition: transform var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  /* Preview panel */
  .work-preview {
    position: sticky;
    top: 5.5rem;
    height: 340px;
    border-radius: 4px;
    overflow: hidden;
  }

  .preview-default {
    position: absolute;
    inset: 0;
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    color: var(--ink-4);
    text-align: center;
    line-height: 1.6;
    opacity: 1;
    transition: opacity var(--dur) var(--ease);
  }

  .work-preview.has-hover .preview-default {
    opacity: 0;
    pointer-events: none;
  }

  .preview-card {
    position: absolute;
    inset: 0;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
    pointer-events: none;
  }

  .preview-card.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .pc-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .pc-metric {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .pc-subtitle {
    font-size: 0.8125rem;
    line-height: 1.5;
    margin-bottom: 1.25rem;
  }

  .pc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .pc-tag {
    font-size: 0.6875rem;
    border: 1px solid;
    border-radius: 9999px;
    padding: 0.15em 0.6em;
  }

  /* Mobile: hide preview */
  @media (max-width: 840px) {
    .work-layout {
      grid-template-columns: 1fr;
    }
    .work-preview {
      display: none;
    }
    .work-link {
      grid-template-columns: 2rem 1fr auto auto;
      gap: 0.75rem;
    }
  }
</style>

<script>
  const items = document.querySelectorAll<HTMLElement>('.work-item');
  const cards = document.querySelectorAll<HTMLElement>('.preview-card');
  const panel = document.querySelector<HTMLElement>('.work-preview');

  function activate(slug: string) {
    panel?.classList.add('has-hover');
    cards.forEach(c => c.classList.toggle('is-active', c.dataset.for === slug));
  }

  function deactivate() {
    panel?.classList.remove('has-hover');
    cards.forEach(c => c.classList.remove('is-active'));
  }

  items.forEach(item => {
    item.addEventListener('mouseenter', () => activate(item.dataset.slug!));
    item.addEventListener('mouseleave', deactivate);
  });
</script>
