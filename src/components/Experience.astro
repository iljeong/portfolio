---
// Experience — 직무를 가로지르는 역량 4개. 질적 서술(숫자는 Short Profile·Work가 소유 → 중복 제거)
// 박스 대신 헤어라인 ledger 레이아웃 (테두리 노이즈 ↓, 여백 ↑)
const items = [
  {
    title: '콘텐츠·상품 기획',
    desc: '강사 분석부터 커리큘럼·상세페이지·런칭까지 교육 상품의 처음과 끝을 맡고, 페이지를 기능 나열이 아닌 “이해 순서”로 다시 짭니다.',
    icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/>',
  },
  {
    title: '데이터 분석 · VoC',
    desc: '리뷰와 로그를 감정 분석·통계 검정으로 읽어, 흩어진 불만을 고객 여정 위 하나의 원인 구조로 모읍니다.',
    icon: '<path d="M3 3v18h18"/><rect x="7" y="11" width="3" height="6"/><rect x="12.5" y="7" width="3" height="10"/><rect x="18" y="13" width="3" height="4"/>',
  },
  {
    title: 'AI 서비스 · 자동화',
    desc: '문제 정의와 추천·QA 기준을 직접 설계하고 AI를 도구로 써서, 서비스와 콘텐츠 파이프라인을 만들어 배포합니다.',
    icon: '<path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/>',
  },
  {
    title: '브랜드 · 팀 운영',
    desc: '브랜드를 직접 창업해 시즌을 굴리고, 여러 직군의 팀을 PM으로 이어 결과물을 끝까지 책임집니다.',
    icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
];
---

<section class="exp-section">
  <div class="container">
    <p class="label exp-head" data-reveal>Experience</p>

    <div class="exp-grid">
      {items.map((it, i) => (
        <article class="exp-item" data-reveal style={`--reveal-delay:${i * 70}ms`}>
          <span class="exp-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={it.icon} />
          </span>
          <div class="exp-body">
            <h3 class="exp-title">{it.title}</h3>
            <p class="exp-desc">{it.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .exp-section { padding: 4.5rem 0 1rem; }
  .exp-head { margin-bottom: 1.75rem; }

  .exp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 3.5rem;
    row-gap: 0;
  }

  /* 박스 대신 상단 헤어라인 ledger */
  .exp-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: start;
    padding: 1.75rem 0;
    border-top: 1px solid var(--line);
  }

  .exp-icon {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r-lg);
    background: var(--accent-bg);
    color: var(--accent);
    flex-shrink: 0;
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .exp-item:hover .exp-icon { background: var(--accent); color: #fff; }

  .exp-title {
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1.3;
    margin: 0.25rem 0 0.5rem;
    word-break: keep-all;
  }
  .exp-desc {
    font-size: var(--text-caption);
    color: var(--ink-3);
    line-height: 1.7;
    word-break: keep-all;
  }

  @media (max-width: 680px) {
    .exp-grid { grid-template-columns: 1fr; }
    .exp-item { padding: 1.5rem 0; }
  }
</style>
