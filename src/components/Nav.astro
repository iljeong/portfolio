---
const base = import.meta.env.BASE_URL;
---

<header class="nav" id="nav">
  <div class="container nav-inner">
    <a href={base} class="nav-logo">서정일</a>
    <nav class="nav-right">
      <a href={`${base}#work`} class="nav-link">Work</a>
      <a href={`${base}#about`} class="nav-link">About</a>
      <a href={`${base}/deck.html`} class="nav-deck">PPT 버전</a>
      <a href="mailto:seobgak11@naver.com" class="nav-cta" aria-label="이메일로 연락하기">연락하기 ↗</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    transition:
      background var(--dur) var(--ease),
      border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
    border-bottom: 1px solid transparent;
  }

  .nav.is-scrolled {
    background: rgba(255, 255, 255, 0.90);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    border-color: var(--line);
    box-shadow: var(--shadow-sm);
  }

  .nav-inner {
    height: 3.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: var(--text-body);   /* 15px */
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    transition: color var(--dur-fast) var(--ease);
  }

  .nav-logo:hover { color: var(--accent); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.875rem;
  }

  .nav-link {
    font-size: var(--text-base);   /* 14px */
    color: var(--ink-2);
    transition: color var(--dur-fast) var(--ease);
  }

  .nav-link:hover { color: var(--ink); }

  .nav-cta {
    font-size: var(--text-sm);     /* 12px */
    font-weight: 500;
    color: #ffffff;
    background: var(--ink);
    padding: 0.4em 1em;
    border-radius: var(--r-full);
    transition: opacity var(--dur-fast) var(--ease);
  }

  .nav-cta:hover {
    opacity: 0.75;
  }

  .nav-deck {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink-2);
    border: 1px solid var(--line);
    padding: 0.35em 0.9em;
    border-radius: var(--r-full);
    transition:
      border-color var(--dur-fast) var(--ease),
      color        var(--dur-fast) var(--ease);
  }

  .nav-deck:hover {
    border-color: var(--ink);
    color: var(--ink);
  }

  @media (max-width: 480px) {
    .nav-right { gap: 1rem; }
    .nav-link  { font-size: var(--text-sm); }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const onScroll = () => nav?.classList.toggle('is-scrolled', window.scrollY > 32);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
