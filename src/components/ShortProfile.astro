---
// Short Profile — 비대칭 bento + "흐름 thread" 시그니처 (라이트 테마, StyleSeed 토큰)

// 3축 = 실제 일하는 순서(흐름) → 번호+thread가 정보(순서)를 인코딩
const axes = [
  { num: '01', title: '문제를 숫자로 좁힙니다', proof: '강사 채널 데이터로 기획 방향을 수정해 신규 강의 6개 출시' },
  { num: '02', title: '흐름과 구조로 해석합니다', proof: '앱 리뷰 37,923건에서 이탈 구조를 고객 여정으로 재정의' },
  { num: '03', title: '직접 만들어 검증합니다', proof: '기획에서 멈추지 않고 구현·배포해 사용 환경에서 확인' },
];

const metrics = [
  { num: '29개+', label: 'AI 자동 생성 피드' },
  { num: '6개', label: '신규 교육 상품 런칭' },
  { num: '37,923건', label: '앱 리뷰 감정 분석' },
  { num: '3시즌', label: '브랜드 출시·운영' },
];
---

<section class="sp-section">
  <div class="container">
    <p class="label sp-head" data-reveal>Short Profile</p>

    <div class="sp-grid">

      <!-- 대표 산출물: 구체적 증거 한 편 (슬로건 반복 X) -->
      <article class="sp-card sp-feature" data-reveal style="--reveal-delay:0ms">
        <div class="sp-feature-media">
          <svg viewBox="0 0 640 360" preserveAspectRatio="xMidYMid slice" role="img" aria-label="신체 정보로 의류 사이즈를 추천하는 일러스트">
            <rect width="640" height="360" fill="#f4f6fb"/>
            <path d="M178 175C178 96 231 60 315 61C405 62 464 114 464 192C464 262 414 301 321 301C226 301 178 251 178 175Z" fill="#E7EEFF"/>
            <g fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M282 88L246 101C238 104 232 110 228 118L204 167L240 184L255 153V280C255 286 260 292 266 292H374C380 292 385 286 385 280V153L400 184L436 167L412 118C408 110 402 104 394 101L358 88C353 107 338 120 320 120C302 120 287 107 282 88Z" stroke="#0A0A0A" stroke-width="2.2"/>
              <path d="M298 94C304 104 336 104 342 94" stroke="#0A0A0A" stroke-width="2.2"/>
              <path d="M255 153C267 162 279 166 292 168" stroke="#D4D4D4" stroke-width="1.6"/>
              <path d="M385 153C373 162 361 166 348 168" stroke="#D4D4D4" stroke-width="1.6"/>
              <path d="M218 116H384" stroke="#737373" stroke-width="1.6"/>
              <path d="M218 108V124" stroke="#737373" stroke-width="1.6"/>
              <path d="M384 108V124" stroke="#737373" stroke-width="1.6"/>
              <path d="M229 184H411" stroke="#737373" stroke-width="1.6"/>
              <path d="M229 176V192" stroke="#737373" stroke-width="1.6"/>
              <path d="M411 176V192" stroke="#737373" stroke-width="1.6"/>
              <path d="M303 116H337" stroke="#D4D4D4" stroke-width="1.6"/>
              <path d="M292 184H348" stroke="#D4D4D4" stroke-width="1.6"/>
              <path d="M386 127L398 119" stroke="#0A0A0A" stroke-width="2.2"/>
            </g>
            <path d="M412 78H450C457.7 78 464 84.3 464 92V108C464 115.7 457.7 122 450 122H412C404.3 122 398 115.7 398 108V106L386 114L398 116V92C398 84.3 404.3 78 412 78Z" fill="#2B5CE6"/>
            <text x="431" y="108" text-anchor="middle" font-family="system-ui, -apple-system, sans-serif" font-size="25" font-weight="700" fill="#f4f6fb">L</text>
            <path d="M446 94L451 99L459 90" fill="none" stroke="#f4f6fb" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="sp-feature-body">
          <h3 class="sp-feature-title">
            신체 정보와 URL로<br /><em>사이즈를 추천</em>합니다.
          </h3>
          <p class="sp-feature-sub">
            문제 정의부터 UX 설계·구현까지 이어가 <b>pullsize.kr</b>에
            배포했습니다.
          </p>
        </div>
      </article>

      <!-- 3축 프로세스: 하나의 카드 안에서 thread로 연결 -->
      <article class="sp-card sp-axes" data-reveal style="--reveal-delay:90ms">
        <ol class="sp-thread">
          {axes.map(a => (
            <li class="sp-step">
              <span class="sp-step-node">{a.num}</span>
              <div class="sp-step-body">
                <h3 class="sp-step-title">{a.title}</h3>
                <p class="sp-step-proof">{a.proof}</p>
              </div>
            </li>
          ))}
        </ol>
      </article>

      <!-- 수치: 액센트 틴트로 변화 -->
      <article class="sp-card sp-metrics" data-reveal style="--reveal-delay:180ms">
        <dl class="sp-metric-list">
          {metrics.map(m => (
            <div class="sp-metric">
              <dt class="sp-metric-num">{m.num}</dt>
              <dd class="sp-metric-label">{m.label}</dd>
            </div>
          ))}
        </dl>
      </article>

    </div>
  </div>
</section>

<style>
  .sp-section { padding: 4.5rem 0 1rem; }
  .sp-head { margin-bottom: 1.25rem; }

  .sp-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    grid-template-areas:
      "feat axes"
      "met  axes";
    gap: 0.75rem;
  }

  /* ── 공통 카드 ── */
  .sp-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-2xl);
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .sp-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: var(--line-strong);
  }

  /* ── 대표 카드 (이미지 블리드) ── */
  .sp-feature {
    grid-area: feat;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #fff;
  }
  .sp-feature-media {
    position: relative;
    flex: 1;
    min-height: 230px;
    overflow: hidden;
    background: #f4f6fb;
  }
  .sp-feature-media svg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    display: block;
    transition: transform var(--dur-slow) var(--ease);
  }
  .sp-feature:hover .sp-feature-media svg { transform: scale(1.03); }
  .sp-feature-body { padding: 1.5rem 1.625rem 1.625rem; border-top: 1px solid var(--line); }
  .sp-feature-title {
    font-size: clamp(1.5rem, 2.7vw, 2rem);
    font-weight: 800; letter-spacing: -0.035em; line-height: 1.22;
    color: var(--ink); margin-bottom: 0.7rem; word-break: keep-all;
  }
  .sp-feature-title em { font-style: normal; color: var(--accent); }
  .sp-feature-sub {
    font-size: var(--text-body); color: var(--ink-2); line-height: 1.7;
    max-width: 40ch; word-break: keep-all;
  }
  .sp-feature-sub b { color: var(--ink); font-weight: 700; }

  /* ── 3축 thread 카드 (시그니처) ── */
  .sp-axes { grid-area: axes; padding: 1.875rem 1.75rem; display: flex; align-items: center; }
  .sp-thread { position: relative; list-style: none; width: 100%; }
  /* 노드를 잇는 세로 실선 = '흐름' */
  .sp-thread::before {
    content: '';
    position: absolute;
    left: 17px; top: 17px; bottom: 17px;
    width: 2px;
    background: linear-gradient(var(--accent), color-mix(in srgb, var(--accent) 25%, transparent));
  }
  .sp-step {
    position: relative;
    display: grid;
    grid-template-columns: 34px 1fr;
    gap: 1rem;
    padding-bottom: 1.875rem;
  }
  .sp-step:last-child { padding-bottom: 0; }
  .sp-step-node {
    position: relative; z-index: 1;
    width: 34px; height: 34px;
    display: grid; place-items: center;
    border-radius: var(--r-full);
    background: var(--accent); color: #fff;
    font-family: var(--font);
    font-size: var(--text-caption); font-weight: 700;
    font-variant-numeric: tabular-nums; letter-spacing: 0.02em;
    box-shadow: 0 0 0 4px #fff;
  }
  .sp-step-title {
    font-size: var(--text-md); font-weight: 700; letter-spacing: -0.02em;
    color: var(--ink); line-height: 1.3; margin-bottom: 0.3rem;
    padding-top: 0.35rem; word-break: keep-all;
  }
  .sp-step-body { min-width: 0; }
  .sp-step-proof {
    font-size: var(--text-caption);
    color: var(--ink-3);
    line-height: 1.6;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  /* ── 수치 카드 (액센트 틴트) ── */
  .sp-metrics {
    grid-area: met;
    display: flex; align-items: center;
    padding: 1.5rem 1.625rem;
    background: var(--accent-bg);
    border-color: color-mix(in srgb, var(--accent) 14%, var(--line));
  }
  .sp-metric-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.125rem 1.5rem; width: 100%; }
  .sp-metric-num {
    font-family: var(--font);
    font-size: clamp(1.625rem, 2.8vw, 2rem);
    font-weight: 800; letter-spacing: -0.035em; color: var(--ink);
    line-height: 1.0; margin-bottom: 0.3rem; font-variant-numeric: tabular-nums;
  }
  .sp-metric-label { font-size: var(--text-xs); color: var(--ink-2); line-height: 1.4; word-break: keep-all; }

  /* ── 반응형 ── */
  @media (max-width: 760px) {
    .sp-grid {
      grid-template-columns: 1fr;
      grid-template-areas: "feat" "axes" "met";
    }
    .sp-axes { padding: 1.625rem 1.5rem; }
    .sp-feature-media { min-height: 200px; }
  }
</style>
