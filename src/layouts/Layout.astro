---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
}
const {
  title = '서정일 포트폴리오',
  description = '사용자 여정에서 문제를 발견하고, 서비스 흐름으로 바꾸는 기획자',
  ogImage: ogImageProp,
  ogUrl: ogUrlProp,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const siteUrl = 'https://iljeong.github.io/portfolio';
const ogImage = ogImageProp ?? `${siteUrl}/images/profile.jpg`;
const ogUrl = ogUrlProp ?? siteUrl;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- OG / Social -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={ogUrl} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <link rel="canonical" href={ogUrl} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <!-- Pretendard Variable — Korean optimized -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link">본문으로 바로가기</a>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    padding: 0.5rem 1rem;
    background: var(--ink);
    color: #fff;
    font-size: 0.875rem;
    border-radius: 0 0 var(--r-sm) var(--r-sm);
    z-index: 9999;
    transition: top 0.1s;
  }
  .skip-link:focus { top: 0; }
</style>
