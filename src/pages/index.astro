---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ShortProfile from '../components/ShortProfile.astro';
import Experience from '../components/Experience.astro';
import WorkList from '../components/WorkList.astro';
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

// Journey — 경력·교육을 하나의 흐름으로 (종료일 기준 최신순). type가 정보를 인코딩
const journey = [
  { type: '교육', period: '2025.06–11', title: '멋쟁이사자처럼 데이터분석 부트캠프 6기', desc: 'Python · 데이터 분석 · 머신러닝 기초 수료' },
  { type: '경력', period: '2023.04–2025.06', title: '아른 사이 · 프로젝트 매니저', desc: '9명 팀 2년 2개월 리드, 텀블벅 펀딩 177% 달성', img: 'images/areun-sai/book-cover.webp' },
  { type: '교육', period: '~2025.02', title: '한림대학교', desc: '사학 전공 · 광고홍보학과 복수전공 졸업' },
  { type: '경력', period: '2024.05–12', title: '패스트캠퍼스(데이원컴퍼니) · 콘텐츠 상품 기획 인턴', desc: '신규 교육 상품 6개 기획·런칭', img: 'images/fastcampus/minshortform.webp' },
  { type: '경력', period: '2021.01–2023.04', title: '살미달라 · 패션 브랜드 대표 · MD', desc: '3인 창업, 3시즌 출시 · 팝업 3회 운영', img: 'images/salmidalla/21ss-product.jpg' },
];
---

<Layout
  title="서정일 포트폴리오"
  description="문제를 숫자로 좁히고 직접 만들어 확인하는 기획자 서정일의 포트폴리오"
>
  <Nav />

  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <section id="main-content" class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="label hero-eyebrow">서정일 · 서비스 흐름을 만드는 기획자</p>
        <h1 class="hero-title">
          문제를 숫자로 좁히고<br />
          <em>직접 만들어 확인합니다.</em>
        </h1>
        <p class="hero-bio">
          사용자 행동과 콘텐츠 데이터에서 막히는 지점을 찾습니다.
          화면 흐름과 운영 방식을 고쳐 산출물로 확인합니다.
        </p>
        <div class="hero-chips">
          {['서비스 기획', '콘텐츠 기획', '데이터 분석', 'AI 자동화'].map(t => (
            <span class="chip">{t}</span>
          ))}
        </div>
        <div class="hero-actions">
          <a href={`${basePath}deck.html`} class="hero-cv">PPT 보기 <span class="hero-cv-arrow">→</span></a>
          <div class="hero-socials">
            <a href="mailto:seobgak11@naver.com" class="hero-social" aria-label="이메일">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            </a>
            <a href="https://github.com/iljeong" target="_blank" rel="noopener noreferrer" class="hero-social" aria-label="GitHub">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49l-.01-1.7c-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.35 1.12 2.92.86.09-.66.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.36 9.36 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.95.68 1.91l-.01 2.83c0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="hero-portrait" data-reveal>
        <div class="hero-portrait-frame">
          <img src={`${basePath}images/profile.jpg`} alt="서정일" />
        </div>
      </div>
    </div>

    <div class="container">
      <dl class="hero-stats" data-reveal>
        {[
          { num: '83%↓', label: '콘텐츠 제작 시간 단축' },
          { num: '6개', label: '신규 교육 상품 런칭' },
          { num: 'pullsize.kr', label: '직접 만든 AI 서비스' },
        ].map(s => (
          <div class="hero-stat">
            <dt class="hero-stat-num">{s.num}</dt>
            <dd class="hero-stat-label">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ═══════════════════ SHORT PROFILE ═══════════════════ -->
  <ShortProfile />

  <!-- ═══════════════════════ EXPERIENCE ═══════════════════ -->
  <Experience />

  <!-- ═══════════════════════ WORK ═══════════════════════ -->
  <WorkList />

  <!-- ═══════════════════════ JOURNEY ══════════════════════ -->
  <section id="about" class="journey-section">
    <div class="container">
      <div class="journey-grid">

        <div class="journey-intro" data-reveal>
          <h2 class="label journey-label">Journey</h2>
          <p class="journey-lead">
            패션 브랜드 운영에서 콘텐츠 기획, 데이터 분석, AI 서비스로.
            분야를 옮기며 쌓은 경력과 학습입니다.
          </p>
          <div class="journey-certs">
            <span class="chip">OPIc IH</span>
            <span class="chip">GTQ 1급</span>
          </div>
        </div>

        <ol class="jr-thread" data-reveal style="--reveal-delay:80ms">
          {journey.map(j => (
            <li class="jr-item">
              <span class={`jr-node ${j.type === '교육' ? 'is-edu' : 'is-career'}`}></span>
              <div class="jr-body">
                <div class="jr-meta">
                  <span class={`jr-tag ${j.type === '교육' ? 'is-edu' : 'is-career'}`}>{j.type}</span>
                  <span class="jr-period">{j.period}</span>
                </div>
                <p class="jr-title">{j.title}</p>
                <p class="jr-desc">{j.desc}</p>
              </div>
            </li>
          ))}
        </ol>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════ FOOTER ═════════════════════ -->
  <footer class="footer">
    <div class="container footer-inner">
      <div>
        <p class="footer-name">서정일</p>
        <p class="footer-tag">
          문제를 숫자로 좁히고<br />직접 만들어 확인하는 기획자
        </p>
      </div>
      <div class="footer-links">
        <a href="mailto:seobgak11@naver.com" class="footer-link">seobgak11@naver.com ↗</a>
        <a href="https://github.com/iljeong" target="_blank" rel="noopener noreferrer" class="footer-link">GitHub ↗</a>
      </div>
    </div>
    <div class="container">
      <p class="footer-copy">© 2026 서정일 · Built with Claude Code &amp; Codex</p>
    </div>
  </footer>

</Layout>

<style>
  /* ── HERO ───────────────────────────────────── */

  .hero { position: relative; padding: 7rem 0 4rem; }
  .hero > .container { position: relative; z-index: 1; }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    z-index: 0;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 58px 58px;
    -webkit-mask-image: radial-gradient(115% 75% at 72% 12%, #000 0%, transparent 62%);
    mask-image: radial-gradient(115% 75% at 72% 12%, #000 0%, transparent 62%);
    opacity: 0.55;
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    align-items: center;
    gap: 4rem;
    margin-bottom: 3.5rem;
  }

  .hero-text { min-width: 0; animation: riseIn 0.7s var(--ease-out) both; }
  .hero-eyebrow { margin-bottom: 1.5rem; }
  .hero-chips { max-width: 100%; }

  .hero-title {
    font-size: clamp(2.375rem, 4.9vw, 3.875rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.18;
    color: var(--ink);
    margin-bottom: 1.875rem;
    word-break: keep-all;
  }
  .hero-title em { font-style: normal; color: var(--accent); }

  .hero-bio {
    font-size: var(--text-body);
    color: var(--ink-2);
    line-height: 1.75;
    max-width: 42ch;
    margin-bottom: 1.5rem;
    word-break: keep-all;
  }

  .hero-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 2rem; }

  .hero-actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }

  .hero-cv {
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.75rem 1.375rem;
    background: var(--ink); color: #fff;
    border-radius: var(--r-full);
    font-size: var(--text-base); font-weight: 600;
    transition: background var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .hero-cv:hover { background: var(--accent); transform: translateY(-2px); }
  .hero-cv-arrow { transition: transform var(--dur) var(--ease); }
  .hero-cv:hover .hero-cv-arrow { transform: translateX(3px); }

  .hero-socials { display: flex; gap: 0.5rem; }
  .hero-social {
    display: grid; place-items: center;
    width: 42px; height: 42px;
    border: 1px solid var(--line-strong);
    border-radius: var(--r-full);
    color: var(--ink-2);
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .hero-social:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

  /* Portrait */
  .hero-portrait {
    display: flex; justify-content: center;
    animation: riseIn 0.8s var(--ease-out) both;
    animation-delay: 0.12s;
  }
  .hero-portrait-frame {
    position: relative;
    width: min(340px, 82%);
    aspect-ratio: 1;
    border-radius: var(--r-full);
    padding: 12px;
    background: var(--accent-bg);
    box-shadow: var(--shadow-lg);
  }
  .hero-portrait-frame::before {
    content: '';
    position: absolute; inset: -7px;
    border-radius: var(--r-full);
    border: 1.5px dashed color-mix(in srgb, var(--accent) 50%, transparent);
  }
  .hero-portrait-frame img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 18%;
    border-radius: var(--r-full);
    border: 1px solid var(--line);
  }

  /* Stats row */
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    border-top: 1px solid var(--line);
    padding-top: 1.75rem;
    animation: riseIn 0.7s var(--ease-out) both;
    animation-delay: 0.2s;
  }
  .hero-stat { display: flex; flex-direction: column; align-items: flex-start; gap: 0.45rem; }
  .hero-stat-num {
    font-family: var(--font);
    font-size: clamp(1.875rem, 3.3vw, 2.625rem);
    font-weight: 800; letter-spacing: -0.04em;
    color: var(--ink); line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .hero-stat-label {
    font-size: var(--text-caption); color: var(--ink-3);
    line-height: 1.45; word-break: keep-all;
  }

  @media (max-width: 860px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; margin-bottom: 2.75rem; }
    .hero-portrait { order: -1; justify-content: flex-start; }
    .hero-portrait-frame { width: 150px; padding: 7px; }
  }

  @media (max-width: 560px) {
    .hero { padding: 6rem 0 3rem; }
    .hero-title { font-size: clamp(1.75rem, 7.2vw, 2.375rem); }
    .hero-stats { grid-template-columns: 1fr 1fr; gap: 1.25rem 1rem; }
  }

  /* ── ABOUT / JOURNEY ────────────────────────── */

  .journey-section {
    padding: 5.5rem 0 6rem;
    border-top: 1px solid var(--line);
    scroll-margin-top: 4rem;
  }

  .journey-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 4rem;
  }

  .journey-intro { align-self: start; position: sticky; top: 5rem; }
  .journey-label { margin-bottom: 1rem; }
  .journey-lead {
    font-size: var(--text-body);
    color: var(--ink-2);
    line-height: 1.75;
    max-width: 34ch;
    word-break: keep-all;
  }
  .journey-certs { display: flex; gap: 0.4rem; margin-top: 1.5rem; }

  @media (max-width: 760px) {
    .journey-grid { grid-template-columns: 1fr; gap: 2rem; }
    .journey-intro { position: static; }
  }

  /* ── Journey timeline (thread 시그니처 재사용) ── */
  .jr-thread { position: relative; list-style: none; margin-top: 0.25rem; }
  .jr-thread::before {
    content: '';
    position: absolute;
    left: 5px; top: 6px; bottom: 10px;
    width: 2px;
    background: linear-gradient(var(--line-strong), var(--line));
  }
  .jr-item {
    position: relative;
    display: grid;
    grid-template-columns: 12px 1fr;
    gap: 1.125rem;
    padding-bottom: 1.625rem;
  }
  .jr-item:last-child { padding-bottom: 0.625rem; }
  .jr-node {
    position: relative; z-index: 1;
    width: 12px; height: 12px; margin-top: 0.3rem;
    border-radius: var(--r-full);
    background: #fff;
    box-shadow: 0 0 0 3px #fff;
  }
  .jr-node.is-career { border: 3px solid var(--accent); }
  .jr-node.is-edu { border: 3px solid var(--ink-4); }
  .jr-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem; }
  .jr-tag {
    font-size: var(--text-2xs); font-weight: 700; letter-spacing: 0.02em;
    padding: 0.12rem 0.45rem; border-radius: var(--r-sm); line-height: 1.5;
  }
  .jr-tag.is-career { color: var(--accent); background: var(--accent-bg); }
  .jr-tag.is-edu { color: var(--ink-2); background: var(--surface); border: 1px solid var(--line); }
  .jr-period {
    font-family: var(--font); font-size: var(--text-xs); color: var(--ink-3);
    font-variant-numeric: tabular-nums; letter-spacing: 0.01em;
  }
  .jr-title {
    font-size: var(--text-body); font-weight: 600; letter-spacing: -0.015em;
    color: var(--ink); line-height: 1.4; margin-bottom: 0.2rem; word-break: keep-all;
  }
  .jr-desc { font-size: var(--text-caption); color: var(--ink-3); line-height: 1.55; word-break: keep-all; }
  /* ── FOOTER ─────────────────────────────────── */

  .footer {
    border-top: 1px solid var(--line);
    padding: 3rem 0 2rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .footer-name {
    font-size: var(--text-body);    /* 15px */
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.375rem;
  }

  .footer-tag {
    font-size: var(--text-caption); /* 13px */
    color: var(--ink-3);
    line-height: 1.65;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.375rem;
  }

  .footer-link {
    font-size: var(--text-base);    /* 14px */
    color: var(--accent);
    transition: opacity var(--dur-fast) var(--ease);
  }

  .footer-link:hover { opacity: 0.7; }

  .footer-copy {
    font-size: var(--text-xs);      /* 11px */
    color: var(--ink-3);
    letter-spacing: 0.02em;
  }

  @media (max-width: 600px) {
    .footer-inner { flex-direction: column; }
    .footer-links { align-items: flex-start; }
  }
</style>
