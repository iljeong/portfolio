---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import WorkList from '../components/WorkList.astro';
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
---

<Layout
  title="서정일 포트폴리오"
  description="사용자 문제를 데이터로 구조화하고, 서비스 흐름으로 검증하는 기획자 서정일의 포트폴리오"
>
  <Nav />

  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <section id="main-content" class="hero">
    <div class="container">
      <p class="label hero-label">Portfolio</p>
      <h1 class="hero-title">
        문제를 찾고,<br />
        구조를 잡고,<br />
        <em>직접 만듭니다.</em>
      </h1>
      <div class="hero-foot">
        <p class="hero-sub">
          데이터 분석 · 콘텐츠 기획 · AI 자동화<br />
          데이터와 콘텐츠를 기반으로 서비스 흐름을 설계하고, 직접 만듭니다.
        </p>
        <a href="#work" class="hero-scroll">
          Work 보기 <span class="scroll-arrow">↓</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ WORK ═══════════════════════ -->
  <WorkList />

  <!-- ═══════════════════════ ABOUT ══════════════════════ -->
  <section id="about" class="about-section">
    <div class="container">
      <div class="about-grid">

        <div class="about-left">
          <div class="about-profile">
            <img src={`${basePath}images/profile.jpg`} alt="서정일" class="about-avatar" />
            <div>
              <p class="label">About</p>
              <p class="about-name">서정일</p>
            </div>
          </div>
          <p class="about-bio">
            사용자 행동과 콘텐츠 데이터를 바탕으로 문제를 정의하고,
            이를 실제 서비스 흐름과 운영 프로세스로 구체화하는 기획자입니다.
          </p>
          <p class="about-bio" style="margin-top:0.875rem">
            패스트캠퍼스 신규 교육 상품 6개 기획, 앱 리뷰 37,923건 분석,
            콘텐츠 제작 시간 3시간 → 30분 단축 프로젝트를 진행했습니다.
          </p>
          <div class="about-chips">
            {['서비스 기획', '콘텐츠 기획', '데이터 분석', 'AI 자동화', 'IA 설계'].map(t => (
              <span class="chip">{t}</span>
            ))}
          </div>
          <div class="about-cta">
            <a href="mailto:seobgak11@naver.com" class="about-cta-btn">이메일 보내기 ↗</a>
            <a href={`${basePath}deck.html`} class="about-cta-btn">PPT 웹 버전 보기 ↗</a>
          </div>
        </div>

        <div class="about-right">
          <!-- Career -->
          <div class="block-wrap">
            <p class="label block-label">Career</p>
            <ul class="career-list">
              {[
                { period: '2024.05–12',     company: '패스트캠퍼스 (데이원컴퍼니)', role: '콘텐츠 상품 기획자 · 인턴' },
                { period: '2023.04–2025.06',  company: '아른 사이',                   role: '프로젝트 매니저' },
                { period: '2021.01–2023.04',  company: '살미달라',                    role: '패션 브랜드 대표 · MD' },
              ].map(c => (
                <li class="career-item">
                  <span class="career-period">{c.period}</span>
                  <div>
                    <p class="career-company">{c.company}</p>
                    <p class="career-role">{c.role}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <!-- Education -->
          <div class="block-wrap">
            <p class="label block-label">Education</p>
            <p class="edu-school">한림대학교</p>
            <p class="edu-dept">사학전공 · 광고홍보학과 — 2025.02 졸업</p>
            <div class="edu-chips">
              <span class="chip">OPIc IH</span>
              <span class="chip">GTQ 1급</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════ FOOTER ═════════════════════ -->
  <footer class="footer">
    <div class="container footer-inner">
      <div>
        <p class="footer-name">서정일</p>
        <p class="footer-tag">
          사용자 문제를 데이터로 구조화하고,<br />서비스 흐름으로 검증하는 기획자
        </p>
      </div>
      <div class="footer-links">
        <a href="mailto:seobgak11@naver.com" class="footer-link">seobgak11@naver.com ↗</a>
      </div>
    </div>
    <div class="container">
      <p class="footer-copy">© 2026 서정일</p>
    </div>
  </footer>

</Layout>

<style>
  /* ── HERO ───────────────────────────────────── */

  .hero {
    padding: 7rem 0 3rem;
  }

  .hero-label { margin-bottom: 2.25rem; }

  .hero-title {
    font-size: clamp(2.625rem, 7.5vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.06;
    color: var(--ink);
    margin-bottom: 2.75rem;
  }

  .hero-title em {
    font-style: normal;
    color: var(--accent);
  }

  .hero-foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    border-top: 1px solid var(--line);
    padding-top: 1.375rem;
  }

  .hero-sub {
    font-size: var(--text-body);   /* 15px */
    color: var(--ink-2);
    line-height: 1.65;
    max-width: 100%;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  .hero-scroll {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-caption);  /* 13px */
    color: var(--ink-3);
    white-space: nowrap;
    transition: color var(--dur-fast) var(--ease);
  }

  .hero-scroll:hover { color: var(--ink); }

  .scroll-arrow {
    display: inline-block;
    animation: bob 2s var(--ease-out) infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(5px); }
  }

  @media (max-width: 860px) {
    .hero-foot { flex-direction: column; align-items: flex-start; }
    .hero-sub {
      word-break: break-all;
      overflow-wrap: anywhere;
    }
  }

  /* ── ABOUT ──────────────────────────────────── */

  .about-section {
    padding: 5rem 0 6rem;
    border-top: 1px solid var(--line);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }

  .about-profile {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .about-avatar {
    width: 72px;
    height: 72px;
    border-radius: var(--r-full);
    object-fit: cover;
    object-position: center top;
    border: 1px solid var(--line);
    flex-shrink: 0;
  }

  .about-name {
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-top: 0.375rem;
  }

  .about-bio {
    font-size: var(--text-body);   /* 15px */
    color: var(--ink-2);
    line-height: 1.75;
    max-width: 400px;
  }

  .about-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.5rem;
  }

  /* Career */
  .block-wrap  { margin-bottom: 2.25rem; }
  .block-label { margin-bottom: 0.875rem; }

  .career-list {
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .career-item {
    display: flex;
    gap: 1.125rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
  }

  .career-period {
    font-size: var(--text-xs);      /* 11px */
    color: var(--ink-4);
    min-width: 7.5rem;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    padding-top: 0.1em;
  }

  .career-company {
    font-size: var(--text-body);    /* 15px */
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: 0.15rem;
  }

  .career-role {
    font-size: var(--text-caption); /* 13px */
    color: var(--ink-3);
  }

  /* Education */
  .edu-school {
    font-size: var(--text-body);    /* 15px */
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-bottom: 0.2rem;
  }

  .edu-dept {
    font-size: var(--text-caption); /* 13px */
    color: var(--ink-3);
    margin-bottom: 0.875rem;
  }

  .edu-chips { display: flex; gap: 0.4rem; }

  /* About CTA */
  .about-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .about-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.625rem 1rem;
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--ink);
    background: var(--surface);
    transition:
      border-color var(--dur-fast) var(--ease),
      background   var(--dur-fast) var(--ease),
      color        var(--dur-fast) var(--ease);
  }

  .about-cta-btn:hover {
    border-color: var(--ink);
    background: var(--ink);
    color: #fff;
  }

  @media (max-width: 760px) {
    .about-grid { grid-template-columns: 1fr; gap: 3rem; }
    .career-period { min-width: 6rem; }
  }

  /* ── FOOTER ─────────────────────────────────── */

  .footer {
    border-top: 1px solid var(--line);
    padding: 3rem 0 2rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .footer-name {
    font-size: var(--text-body);    /* 15px */
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.375rem;
  }

  .footer-tag {
    font-size: var(--text-caption); /* 13px */
    color: var(--ink-3);
    line-height: 1.65;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.375rem;
  }

  .footer-link {
    font-size: var(--text-base);    /* 14px */
    color: var(--accent);
    transition: opacity var(--dur-fast) var(--ease);
  }

  .footer-link:hover { opacity: 0.7; }

  .footer-copy {
    font-size: var(--text-xs);      /* 11px */
    color: var(--ink-4);
    letter-spacing: 0.02em;
  }

  @media (max-width: 600px) {
    .footer-inner { flex-direction: column; }
    .footer-links { align-items: flex-start; }
  }
</style>
