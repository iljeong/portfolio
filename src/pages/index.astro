---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import WorkList from '../components/WorkList.astro';
---

<Layout
  title="서정일 — 서비스 기획자"
  description="사용자 여정에서 문제를 발견하고, 서비스 흐름으로 바꾸는 기획자 서정일의 포트폴리오"
>
  <Nav />

  <!-- ═══════════════════════════════════════════ HERO -->
  <section class="hero">
    <div class="container">
      <p class="hero-label label">PORTFOLIO · SERVICE PLANNER</p>
      <h1 class="hero-title">
        사용자 여정에서<br />
        문제를 발견하고,<br />
        <em>서비스 흐름으로</em><br />
        해결합니다.
      </h1>
      <div class="hero-foot">
        <p class="hero-sub">
          데이터 분석 · 콘텐츠 기획 · AI 자동화<br />
          현재 새로운 기회를 찾고 있습니다.
        </p>
        <a href="#work" class="hero-scroll">
          <span>Work 보기</span>
          <span class="scroll-arrow">↓</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ WORK -->
  <WorkList />

  <!-- ═══════════════════════════════════════════ ABOUT -->
  <section id="about" class="about-section">
    <div class="container">
      <div class="about-grid">

        <div class="about-left">
          <p class="label" style="margin-bottom:1.5rem">ABOUT</p>
          <p class="about-bio">
            패스트캠퍼스에서 신규 교육 상품을 기획하고, 37,923건의 앱 리뷰를 분석해
            고객 이탈 구조를 재정의했으며, AI 파이프라인으로 콘텐츠 제작 시간을
            80% 단축했습니다.
          </p>
          <p class="about-bio" style="margin-top:0.875rem">
            문제를 데이터로 구조화하고, 실제로 작동하는 서비스 흐름으로 바꾸는 일을
            해왔습니다.
          </p>
          <div class="about-tags">
            <span class="chip">서비스 기획</span>
            <span class="chip">콘텐츠 기획</span>
            <span class="chip">데이터 분석</span>
            <span class="chip">AI 자동화</span>
            <span class="chip">IA 설계</span>
          </div>
        </div>

        <div class="about-right">
          <div class="career-block">
            <p class="label" style="margin-bottom:1rem">CAREER</p>
            <div class="career-rows">
              <div class="cr">
                <span class="cr-period">2024.05–12</span>
                <div>
                  <p class="cr-company">패스트캠퍼스 (데이원컴퍼니)</p>
                  <p class="cr-role">콘텐츠 상품 기획자</p>
                </div>
              </div>
              <div class="cr">
                <span class="cr-period">2023.04–25.06</span>
                <div>
                  <p class="cr-company">아른 사이</p>
                  <p class="cr-role">프로젝트 매니저</p>
                </div>
              </div>
              <div class="cr">
                <span class="cr-period">2021.01–23.04</span>
                <div>
                  <p class="cr-company">살미달라</p>
                  <p class="cr-role">패션 브랜드 대표 · MD</p>
                </div>
              </div>
            </div>
          </div>

          <div class="edu-block">
            <p class="label" style="margin-bottom:0.75rem">EDUCATION</p>
            <p class="edu-school">한림대학교</p>
            <p class="edu-dept">사학전공 · 광고홍보학과 — 2025.02</p>
            <div class="cert-row">
              <span class="chip">OPIc IH</span>
              <span class="chip">GTQ 1급</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-left">
        <p class="footer-name">서정일</p>
        <p class="footer-tagline">
          사용자 여정에서 문제를 발견하고,<br />서비스 흐름으로 바꾸는 기획자
        </p>
      </div>
      <div class="footer-right">
        <a href="mailto:seobgak11@naver.com" class="footer-link">
          seobgak11@naver.com ↗
        </a>
        <a href="tel:010-9355-2605" class="footer-link">
          010-9355-2605
        </a>
      </div>
    </div>
    <div class="container">
      <p class="footer-copy">© 2026 서정일</p>
    </div>
  </footer>

</Layout>

<style>
  /* ── HERO ── */
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding: 7rem 0 5rem;
  }

  .hero-label {
    margin-bottom: 2.5rem;
  }

  .hero-title {
    font-size: clamp(2.75rem, 7.5vw, 5.25rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: 3rem;
  }

  .hero-title em {
    font-style: normal;
    color: var(--accent);
  }

  .hero-foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
  }

  .hero-sub {
    font-size: 0.9375rem;
    color: var(--ink-2);
    line-height: 1.65;
  }

  .hero-scroll {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--ink-3);
    white-space: nowrap;
    transition: color var(--dur-fast) var(--ease);
  }

  .hero-scroll:hover { color: var(--ink); }

  .scroll-arrow {
    display: inline-block;
    animation: bob 1.8s ease-in-out infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(4px); }
  }

  @media (max-width: 600px) {
    .hero-foot { flex-direction: column; align-items: flex-start; }
  }

  /* ── ABOUT ── */
  .about-section {
    padding: 5rem 0 6rem;
    border-top: 1px solid var(--line);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }

  .about-bio {
    font-size: 1rem;
    color: var(--ink-2);
    line-height: 1.75;
    max-width: 420px;
  }

  .about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }

  /* Career */
  .career-block { margin-bottom: 2.5rem; }

  .career-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .cr {
    display: flex;
    gap: 1.25rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
  }

  .cr-period {
    font-size: 0.75rem;
    color: var(--ink-4);
    min-width: 8rem;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .cr-company {
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 0.15rem;
  }

  .cr-role {
    font-size: 0.8125rem;
    color: var(--ink-3);
  }

  /* Education */
  .edu-school {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 0.2rem;
  }

  .edu-dept {
    font-size: 0.875rem;
    color: var(--ink-3);
    margin-bottom: 0.875rem;
  }

  .cert-row {
    display: flex;
    gap: 0.5rem;
  }

  @media (max-width: 760px) {
    .about-grid { grid-template-columns: 1fr; gap: 3rem; }
    .cr-period { min-width: 6rem; }
  }

  /* ── FOOTER ── */
  .footer {
    border-top: 1px solid var(--line);
    padding: 3rem 0 2rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .footer-name {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }

  .footer-tagline {
    font-size: 0.8125rem;
    color: var(--ink-3);
    line-height: 1.6;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--accent);
    transition: opacity var(--dur-fast) var(--ease);
  }

  .footer-link:hover { opacity: 0.7; }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--ink-4);
  }

  @media (max-width: 600px) {
    .footer-inner { flex-direction: column; }
    .footer-right { align-items: flex-start; }
  }
</style>
