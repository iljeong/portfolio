---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { projects } from '../../data/projects';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (() => {
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Layout
  title={`${project.title} — 서정일`}
  description={project.subtitle}
>
  <Nav />

  <main class="project-page">
    <!-- Breadcrumb -->
    <div class="container breadcrumb-row">
      <a href={base} class="breadcrumb-link">← 전체 프로젝트</a>
    </div>

    <!-- Header -->
    <header class="project-header">
      <div class="container">
        <p class="proj-chapter">{project.category} · {project.period}</p>
        <h1 class="proj-title">{project.title}</h1>
        <p class="proj-subtitle">{project.subtitle}</p>
        <hr class="proj-divider" />
        <div class="proj-tags">
          {project.tags.map(tag => <span class="chip">{tag}</span>)}
        </div>
      </div>
    </header>

    <!-- Content -->
    <div class="container project-body">

      <!-- Problem -->
      <section class="proj-section">
        <p class="proj-section-label">PROBLEM</p>
        <div class="callout-box">
          <div class="callout-bar"></div>
          <div class="callout-inner">
            <p class="callout-label">문제 정의</p>
            <p class="callout-text">{project.content.problem}</p>
          </div>
        </div>
      </section>

      <!-- Approach -->
      <section class="proj-section">
        <p class="proj-section-label">APPROACH</p>
        <div class="process-list">
          {project.content.approach.map(a => (
            <div class="process-item">
              <span class="process-num">{a.num}</span>
              <div class="process-body">
                <p class="process-step">{a.step}</p>
                <p class="process-desc">{a.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Results -->
      <section class="proj-section">
        <p class="proj-section-label">RESULTS</p>
        <div class="results-grid">
          {project.content.results.map(r => (
            <div class="result-card">
              <p class="result-label">{r.label}</p>
              <p class="result-desc">{r.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Contribution scope -->
      <section class="proj-section">
        <p class="proj-section-label">CONTRIBUTION</p>
        <div class="contrib-box">
          <div class="contrib-row">
            <span class="contrib-key">Role</span>
            <span class="contrib-val">{project.content.contribution.role}</span>
          </div>
          <hr class="contrib-divider" />
          <div class="contrib-row">
            <span class="contrib-key">Scope</span>
            <span class="contrib-val">{project.content.contribution.scope}</span>
          </div>
          <hr class="contrib-divider" />
          <div class="contrib-row">
            <span class="contrib-key">Output</span>
            <span class="contrib-val">{project.content.contribution.output}</span>
          </div>
        </div>
      </section>

      <!-- Back link -->
      <div class="back-row">
        <a href={base} class="back-link">← 전체 프로젝트로 돌아가기</a>
      </div>
    </div>
  </main>

  <!-- Simple footer -->
  <footer class="proj-footer">
    <div class="container">
      <span>서정일 · seobgak11@naver.com</span>
    </div>
  </footer>
</Layout>

<style>
  .project-page {
    padding-top: 3.25rem; /* nav height */
  }

  /* Breadcrumb */
  .breadcrumb-row {
    padding-top: 1.5rem;
    padding-bottom: 0;
  }

  .breadcrumb-link {
    font-size: 0.8125rem;
    color: var(--c-sky);
    transition: color var(--dur) var(--ease);
  }

  .breadcrumb-link:hover {
    color: var(--c-sky-deep);
  }

  /* Header */
  .project-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--c-hairline);
    margin-bottom: 3.5rem;
    background: var(--c-canvas);
  }

  .proj-chapter {
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--c-sky);
    text-transform: uppercase;
    margin-bottom: 0.875rem;
  }

  .proj-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--c-ink);
    line-height: 1.2;
    margin-bottom: 0.75rem;
    max-width: 720px;
  }

  .proj-subtitle {
    font-size: 0.9375rem;
    color: var(--c-body);
    margin-bottom: 1.5rem;
    max-width: 600px;
  }

  .proj-divider {
    border: none;
    height: 1px;
    background: var(--c-hairline);
    margin-bottom: 1.25rem;
    max-width: 720px;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  /* Body sections */
  .project-body {
    padding-bottom: 5rem;
    max-width: 760px;
  }

  .proj-section {
    margin-bottom: 3rem;
  }

  .proj-section-label {
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--c-sky);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  /* Callout box */
  .callout-box {
    display: flex;
    background: var(--c-canvas);
    border: 1px solid var(--c-hairline);
  }

  .callout-bar {
    width: 3px;
    background: var(--c-sky);
    flex-shrink: 0;
  }

  .callout-inner {
    padding: 1.125rem 1.25rem;
  }

  .callout-label {
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    color: var(--c-sky);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .callout-text {
    font-size: 0.9375rem;
    color: var(--c-body);
    line-height: 1.7;
  }

  /* Process list */
  .process-list {
    border-top: 1px solid var(--c-hairline);
  }

  .process-item {
    display: flex;
    gap: 1.25rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--c-hairline);
    align-items: baseline;
  }

  .process-num {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--c-mute);
    min-width: 2rem;
    letter-spacing: -0.02em;
  }

  .process-step {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--c-ink);
    margin-bottom: 0.2rem;
    letter-spacing: -0.01em;
  }

  .process-desc {
    font-size: 0.875rem;
    color: var(--c-body);
    line-height: 1.55;
  }

  /* Results */
  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1px;
    background: var(--c-hairline);
    border: 1px solid var(--c-hairline);
  }

  .result-card {
    background: var(--c-canvas);
    padding: 1.25rem;
  }

  .result-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--c-sky-deep);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
  }

  .result-desc {
    font-size: 0.875rem;
    color: var(--c-body);
    line-height: 1.55;
  }

  /* Contribution */
  .contrib-box {
    background: var(--c-surface);
    border: 1px solid var(--c-hairline);
    padding: 1.25rem;
  }

  .contrib-row {
    display: flex;
    gap: 1.25rem;
    align-items: baseline;
    padding: 0.5rem 0;
  }

  .contrib-key {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--c-sky);
    text-transform: uppercase;
    min-width: 3.5rem;
  }

  .contrib-val {
    font-size: 0.875rem;
    color: var(--c-body);
    line-height: 1.5;
  }

  .contrib-divider {
    border: none;
    height: 1px;
    background: var(--c-hairline);
  }

  /* Back */
  .back-row {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-hairline);
  }

  .back-link {
    font-size: 0.875rem;
    color: var(--c-sky);
    transition: color var(--dur) var(--ease);
  }

  .back-link:hover {
    color: var(--c-sky-deep);
  }

  /* Footer */
  .proj-footer {
    border-top: 1px solid var(--c-hairline);
    padding: 1.5rem 0;
    font-size: 0.8125rem;
    color: var(--c-mute);
  }
</style>
