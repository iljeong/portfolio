---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { projects } from '../../data/projects';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (() => {
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
const idx = projects.findIndex(p => p.slug === project.slug);
const next = projects[(idx + 1) % projects.length];
---

<Layout
  title={`${project.name} — 서정일`}
  description={project.subtitle}
>
  <Nav />

  <main class="cs-main">

    <!-- ── Header ── -->
    <header class="cs-header">
      <div class="container">
        <a href={base} class="cs-back">← 모든 프로젝트</a>
        <div class="cs-meta-row">
          <span class="label">{project.category}</span>
          <span class="cs-sep">·</span>
          <span class="label">{project.period}</span>
        </div>
        <h1 class="cs-title">{project.title}</h1>
        <p class="cs-sub">{project.subtitle}</p>
        <div class="cs-tags">
          {project.tags.map(t => <span class="chip">{t}</span>)}
        </div>
      </div>
    </header>

    <!-- ── Highlight stat ── -->
    <div class="cs-highlight-bar">
      <div class="container cs-highlight-inner">
        <p class="cs-highlight-num">{project.highlight}</p>
        <p class="cs-highlight-label">핵심 성과</p>
      </div>
    </div>

    <!-- ── Body ── -->
    <div class="container cs-body">

      <!-- Problem -->
      <section class="cs-section">
        <p class="cs-section-label label label--accent">01 · Problem</p>
        <div class="cs-prose">
          <p>{project.content.problem}</p>
        </div>
      </section>

      <hr class="line" />

      <!-- Approach -->
      <section class="cs-section">
        <p class="cs-section-label label label--accent">02 · Approach</p>
        <div class="cs-process">
          {project.content.approach.map(a => (
            <div class="cs-step">
              <span class="cs-step-num">{a.num}</span>
              <div class="cs-step-body">
                <p class="cs-step-name">{a.step}</p>
                <p class="cs-step-desc">{a.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <hr class="line" />

      <!-- Results -->
      <section class="cs-section">
        <p class="cs-section-label label label--accent">03 · Results</p>
        <div class="cs-results">
          {project.content.results.map(r => (
            <div class="cs-result">
              <p class="cs-result-label">{r.label}</p>
              <p class="cs-result-desc">{r.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <hr class="line" />

      <!-- Contribution -->
      <section class="cs-section">
        <p class="cs-section-label label label--accent">04 · Contribution</p>
        <div class="cs-contrib">
          <div class="cc-row">
            <span class="cc-key">Role</span>
            <span class="cc-val">{project.content.contribution.role}</span>
          </div>
          <div class="cc-row">
            <span class="cc-key">Scope</span>
            <span class="cc-val">{project.content.contribution.scope}</span>
          </div>
          <div class="cc-row">
            <span class="cc-key">Output</span>
            <span class="cc-val">{project.content.contribution.output}</span>
          </div>
        </div>
      </section>

    </div>

    <!-- ── Next project ── -->
    <div class="cs-next">
      <div class="container">
        <p class="label" style="margin-bottom:1rem">다음 프로젝트</p>
        <a href={`${base}/projects/${next.slug}`} class="cs-next-link">
          <span class="cs-next-name">{next.name}</span>
          <span class="cs-next-arrow">→</span>
        </a>
      </div>
    </div>

  </main>
</Layout>

<style>
  .cs-main {
    padding-top: 3.5rem; /* nav height */
  }

  /* Header */
  .cs-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--line);
  }

  .cs-back {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--ink-3);
    margin-bottom: 2.5rem;
    transition: color var(--dur-fast) var(--ease);
  }

  .cs-back:hover { color: var(--ink); }

  .cs-meta-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1.25rem;
  }

  .cs-sep { color: var(--ink-4); }

  .cs-title {
    font-size: clamp(1.75rem, 4vw, 2.875rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--ink);
    max-width: 720px;
    margin-bottom: 0.875rem;
  }

  .cs-sub {
    font-size: 1rem;
    color: var(--ink-2);
    max-width: 560px;
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  .cs-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  /* Highlight bar */
  .cs-highlight-bar {
    background: var(--ink);
    padding: 2rem 0;
  }

  .cs-highlight-inner {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
  }

  .cs-highlight-num {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #FFFFFF;
    line-height: 1;
  }

  .cs-highlight-label {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.05em;
  }

  /* Body */
  .cs-body {
    padding: 0 0 5rem;
    max-width: 800px;
  }

  .cs-section {
    padding: 3rem 0;
  }

  .cs-section-label {
    margin-bottom: 1.5rem;
  }

  /* Prose */
  .cs-prose p {
    font-size: 1rem;
    color: var(--ink-2);
    line-height: 1.8;
    max-width: 640px;
  }

  /* Process */
  .cs-process {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .cs-step {
    display: flex;
    gap: 1.5rem;
    padding: 1.125rem 0;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
  }

  .cs-step-num {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--ink-4);
    letter-spacing: -0.02em;
    min-width: 2.25rem;
    line-height: 1;
  }

  .cs-step-name {
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: 0.25rem;
  }

  .cs-step-desc {
    font-size: 0.875rem;
    color: var(--ink-2);
    line-height: 1.55;
  }

  /* Results */
  .cs-results {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  .cs-result {
    background: var(--bg);
    padding: 1.375rem;
  }

  .cs-result-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .cs-result-desc {
    font-size: 0.9375rem;
    color: var(--ink);
    line-height: 1.55;
    font-weight: 500;
  }

  /* Contribution */
  .cs-contrib {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .cc-row {
    display: flex;
    gap: 2rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
  }

  .cc-key {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    min-width: 4rem;
    padding-top: 0.1rem;
  }

  .cc-val {
    font-size: 0.9375rem;
    color: var(--ink-2);
    line-height: 1.55;
  }

  /* Next project */
  .cs-next {
    border-top: 1px solid var(--line);
    padding: 3rem 0 4rem;
  }

  .cs-next-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    transition: color var(--dur-fast) var(--ease);
  }

  .cs-next-link:hover { color: var(--accent); }

  .cs-next-name {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  .cs-next-arrow {
    font-size: 1.25rem;
    transition: transform var(--dur-fast) var(--ease);
  }

  .cs-next-link:hover .cs-next-arrow {
    transform: translateX(4px);
  }
</style>
