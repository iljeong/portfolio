---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Flow from '../../components/Flow.astro';
import Architecture from '../../components/Architecture.astro';
import { projects } from '../../data/projects';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (() => {
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const assetPath = (src: string) => `${basePath}${src.replace(/^\/+/, '')}`;
const idx  = projects.findIndex(p => p.slug === project.slug);
const next = projects[(idx + 1) % projects.length];
const siteUrl = 'https://iljeong.github.io/portfolio';
const pageOgUrl = `${siteUrl}/projects/${project.slug}`;
const problemShort = project.content.problem.split('. ')[0] + '.';
const hasInsights = (project.content.insights ?? []).length > 0;
const shots = project.screenshots ?? [];
---

<Layout
  title={`${project.name} — 서정일`}
  description={project.subtitle}
  ogUrl={pageOgUrl}
>
  <Nav />

  <main id="main-content" class="cs">

    <!-- Header -->
    <header class="cs-header">
      <div class="container">
        <a href={base} class="cs-back">← 모든 프로젝트</a>

        <div class="cs-meta">
          <span class="label label--accent">{project.category}</span>
          <span class="cs-dot">·</span>
          <span class="label">{project.period}</span>
        </div>

        <h1 class="cs-title">{project.title}</h1>
        <p class="cs-sub">{project.subtitle}</p>

        <div class="cs-tag-row">
          {project.tags.map(t => <span class="chip">{t}</span>)}
        </div>
        {project.links && project.links.length > 0 && (
          <div class="cs-link-row">
            {project.links.map(link => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="cs-link-cta">
                {link.label} ↗
              </a>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Highlight stat bar -->
    <div class="cs-stat-bar">
      <div class="container cs-stat-inner">
        <span class="cs-stat-num">{project.kpi ?? project.highlight}</span>
        <span class="cs-stat-label">{project.kpiLabel ?? '핵심 성과'}</span>
      </div>
    </div>

    <!-- TL;DR -->
    <div class="cs-tldr">
      <div class="container cs-tldr-inner">
        <div class="cs-tldr-item">
          <p class="label label--accent cs-tldr-label">문제</p>
          <p class="cs-tldr-text">{problemShort}</p>
        </div>
        <div class="cs-tldr-item">
          <p class="label label--accent cs-tldr-label">역할</p>
          <p class="cs-tldr-text">{project.content.contribution.role}</p>
        </div>
        <div class="cs-tldr-item">
          <p class="label label--accent cs-tldr-label">결과</p>
          <p class="cs-tldr-text">{project.content.results[0]?.desc}</p>
        </div>
      </div>
    </div>

    <!-- Body -->
    <div class="container cs-body">

      {shots.length > 0 && (
        <section class="cs-sec cs-gallery-sec">
          <h2 class="label label--accent cs-sec-label">산출물</h2>
          <div class="cs-gallery-wrap at-start">
            <div class="cs-gallery" data-gallery>
              {shots.map((s, i) => (
                <figure class="cs-gallery-item">
                  {s.url ? (
                    <a href={s.url} target="_blank" rel="noopener noreferrer" class="cs-shot-inner">
                      <img src={assetPath(s.src)} alt={s.caption ?? ''} loading={i === 0 ? 'eager' : 'lazy'} />
                      {s.caption && <div class="cs-shot-overlay"><span>{s.caption} ↗</span></div>}
                    </a>
                  ) : (
                    <div class="cs-shot-inner">
                      <img src={assetPath(s.src)} alt={s.caption ?? ''} loading={i === 0 ? 'eager' : 'lazy'} />
                      {s.caption && <div class="cs-shot-overlay"><span>{s.caption}</span></div>}
                    </div>
                  )}
                </figure>
              ))}
            </div>
            <button type="button" class="cs-gallery-nav is-prev" data-dir="-1" aria-label="이전 산출물">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button type="button" class="cs-gallery-nav is-next" data-dir="1" aria-label="다음 산출물">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
          <p class="cs-gallery-hint">좌우로 넘기거나 화살표로 더 볼 수 있어요.</p>
        </section>
      )}

      <!-- 01 Results -->
      <section class="cs-sec">
        <h2 class="label label--accent cs-sec-label">01 · Results</h2>
        <div class="cs-results">
          {project.content.results.map(r => (
            <div class="cs-result">
              <p class="cs-result-label">{r.label}</p>
              <p class="cs-result-val">{r.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <hr class="line" />

      <!-- 02 Problem -->
      <section class="cs-sec">
        <h2 class="label label--accent cs-sec-label">02 · Problem</h2>
        <p class="cs-prose">{project.content.problem}</p>
      </section>

      <hr class="line" />

      <!-- 03 Approach -->
      <section class="cs-sec">
        <h2 class="label label--accent cs-sec-label">03 · Approach</h2>
        <ol class="cs-steps" role="list">
          {project.content.approach.map(a => (
            <li class="cs-step">
              <span class="cs-step-n">{a.num}</span>
              <div class="cs-step-body">
                <h3 class="cs-step-title">{a.step}</h3>
                <p class="cs-step-desc">{a.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      {project.content.flow && (
        <>
          <hr class="line" />
          <section class="cs-sec">
            <h2 class="label label--accent cs-sec-label">{project.content.flow.title}</h2>
            {project.content.flow.caption && (
              <p class="cs-flow-caption">{project.content.flow.caption}</p>
            )}
            <Flow flow={project.content.flow} />
          </section>
        </>
      )}

      {hasInsights ? (
        <>
          <hr class="line" />
          <section class="cs-sec">
            <h2 class="label label--accent cs-sec-label">04 · Key Insight</h2>
            <div class="cs-insights">
              {project.content.insights!.map(ins => (
                <div class="cs-insight">
                  <span class="cs-insight-num">{ins.num}</span>
                  <div class="cs-insight-body">
                    <h3 class="cs-insight-title">{ins.title}</h3>
                    <p class="cs-insight-desc">{ins.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        </>
      ) : null}

      {project.content.architecture && (
        <>
          <hr class="line" />
          <section class="cs-sec">
            <h2 class="label label--accent cs-sec-label">{project.content.architecture.title}</h2>
            {project.content.architecture.caption && (
              <p class="cs-flow-caption">{project.content.architecture.caption}</p>
            )}
            <Architecture architecture={project.content.architecture} />
          </section>
        </>
      )}

      <hr class="line" />

      <!-- Contribution -->
      <section class="cs-sec">
        <h2 class="label label--accent cs-sec-label">05 · Contribution</h2>
        <dl class="cs-contrib">
          {[
            { k: 'Role',   v: project.content.contribution.role },
            { k: 'Scope',  v: project.content.contribution.scope },
            { k: 'Output', v: project.content.contribution.output },
          ].map(row => (
            <>
              <div class="cc-row">
                <dt class="cc-key">{row.k}</dt>
                <dd class="cc-val">{row.v}</dd>
              </div>
              <hr class="line" />
            </>
          ))}
        </dl>
      </section>

    </div>

    <!-- Next project -->
    <div class="cs-next">
      <div class="container">
        <p class="label" style="margin-bottom:0.875rem">다음 프로젝트</p>
        <a href={`${base}/projects/${next.slug}`} class="cs-next-link">
          <span class="cs-next-name">{next.name}</span>
          <span class="cs-next-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>

  </main>
</Layout>

<script>
  document.querySelectorAll('.cs-gallery-wrap').forEach((wrap) => {
    const gallery = wrap.querySelector('[data-gallery]');
    if (!gallery) return;
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const update = () => {
      const max = gallery.scrollWidth - gallery.clientWidth - 1;
      wrap.classList.toggle('at-start', gallery.scrollLeft <= 0);
      wrap.classList.toggle('at-end', gallery.scrollLeft >= max);
    };
    wrap.querySelectorAll('.cs-gallery-nav').forEach((btn) => {
      btn.addEventListener('click', () => {
        const dir = Number(btn.getAttribute('data-dir'));
        gallery.scrollBy({ left: dir * Math.min(gallery.clientWidth * 0.85, 420), behavior: reduce ? 'auto' : 'smooth' });
      });
    });
    gallery.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  });
</script>

<style>
  .cs { padding-top: 3.25rem; }

  /* Header */
  .cs-header {
    padding: 3.5rem 0 2.75rem;
    border-bottom: 1px solid var(--line);
  }

  .cs-back {
    display: inline-block;
    font-size: var(--text-caption); /* 13px */
    color: var(--ink-3);
    margin-bottom: 2.25rem;
    transition: color var(--dur-fast) var(--ease);
  }

  .cs-back:hover { color: var(--ink); }

  .cs-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.125rem;
  }

  .cs-dot { color: var(--ink-4); font-size: var(--text-xs); }

  .cs-title {
    font-size: clamp(1.625rem, 3.5vw, 2.625rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--ink);
    max-width: 700px;
    margin-bottom: 0.75rem;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  .cs-sub {
    font-size: var(--text-body);    /* 15px */
    color: var(--ink-2);
    max-width: 540px;
    line-height: 1.7;
    margin-bottom: 1.375rem;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  .cs-tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .cs-link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-top: 1rem;
  }

  .cs-link-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.25rem;
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    background: var(--surface);
    color: var(--ink);
    font-size: var(--text-caption);
    font-weight: 700;
    line-height: 1;
    transition:
      border-color var(--dur-fast) var(--ease),
      background var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease);
  }

  .cs-link-cta:hover {
    border-color: var(--ink);
    background: var(--ink);
    color: #fff;
  }

  /* Stat bar */
  .cs-stat-bar {
    background: var(--ink);
    padding: 1.75rem 0;
  }

  .cs-stat-inner {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .cs-stat-num {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 4.5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #FFFFFF;
    line-height: 1;
  }

  .cs-stat-label {
    font-size: var(--text-xs);      /* 11px */
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  /* TL;DR Summary */
  .cs-tldr {
    border-bottom: 1px solid var(--line);
    padding: 2rem 0;
    background: var(--surface);
  }

  .cs-tldr-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    min-width: 0;
  }

  .cs-tldr-item {
    padding: 0 2rem;
    border-left: 1px solid var(--line);
    min-width: 0;
  }

  .cs-tldr-item:first-child {
    padding-left: 0;
    border-left: none;
  }

  .cs-tldr-label { margin-bottom: 0.5rem; }

  .cs-tldr-text {
    font-size: var(--text-body);    /* 15px */
    color: var(--ink-2);
    line-height: 1.65;
    max-width: 100%;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  @media (max-width: 640px) {
    .cs-tldr-inner { grid-template-columns: 1fr; }

    .cs-tldr-item {
      padding: 0;
      border-left: none;
      border-top: 1px solid var(--line);
      padding-top: 1rem;
      margin-top: 1rem;
    }

    .cs-tldr-item:first-child {
      border-top: none;
      padding-top: 0;
      margin-top: 0;
    }
  }

  /* Body */
  .cs-body {
    padding-bottom: 5rem;
    max-width: 760px;
  }

  .cs-sec { padding: 2.75rem 0; }

  .cs-sec-label { margin-bottom: 1.375rem; }

  /* ── 산출물 가로 스크롤 갤러리 ── */
  .cs-gallery-sec { padding-top: 3rem; }
  .cs-gallery-wrap { position: relative; }
  .cs-gallery-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px; height: 40px;
    display: grid; place-items: center;
    border-radius: var(--r-full);
    background: #fff;
    border: 1px solid var(--line-strong);
    color: var(--ink);
    box-shadow: var(--shadow-md);
    cursor: pointer;
    z-index: 2;
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease),
                opacity var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .cs-gallery-nav:hover { background: var(--ink); color: #fff; border-color: var(--ink); }
  .cs-gallery-nav.is-prev { left: 8px; }
  .cs-gallery-nav.is-next { right: 8px; }
  .cs-gallery-wrap.at-start .cs-gallery-nav.is-prev,
  .cs-gallery-wrap.at-end .cs-gallery-nav.is-next { opacity: 0; pointer-events: none; }
  .cs-gallery {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 0.875rem;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--line-strong) transparent;
  }
  .cs-gallery-item {
    position: relative;
    flex: 0 0 auto;
    height: 320px;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--surface);
    scroll-snap-align: start;
    transition: box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .cs-gallery-item:hover { box-shadow: var(--shadow-lg); border-color: var(--line-strong); }
  .cs-gallery-item .cs-shot-inner { height: 100%; }
  .cs-gallery-item .cs-shot-inner img {
    height: 100%;
    width: auto;
    max-width: none;
  }
  .cs-gallery-item:hover .cs-shot-inner img { transform: scale(1.03); }
  .cs-gallery-item:hover .cs-shot-overlay,
  .cs-gallery-item:focus-within .cs-shot-overlay { opacity: 1; }
  .cs-gallery-hint {
    margin-top: 0.625rem;
    font-size: var(--text-xs);
    color: var(--ink-3);
    letter-spacing: 0.01em;
  }
  /* 터치 기기: hover 불가 → 캡션 상시 노출, 화살표 숨김(스와이프) */
  @media (hover: none) {
    .cs-gallery-item .cs-shot-overlay { opacity: 1; }
    .cs-gallery-nav { display: none; }
  }
  @media (max-width: 640px) {
    .cs-gallery-item { height: 240px; }
  }

  .cs-flow-caption {
    font-size: var(--text-caption);
    color: var(--ink-3);
    line-height: 1.65;
    margin: -0.5rem 0 1.375rem;
    max-width: 620px;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  /* Prose */
  .cs-prose {
    font-size: var(--text-body);    /* 15px */
    color: var(--ink-2);
    line-height: 1.8;
    max-width: 620px;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  /* Process steps */
  .cs-steps {
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .cs-step {
    display: flex;
    gap: 1.375rem;
    padding: 1.125rem 0;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
  }

  .cs-step-body {
    min-width: 0;
  }

  .cs-step-n {
    font-size: var(--text-2xl);     /* 24px */
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--ink-4);
    min-width: 2.5rem;
    line-height: 1;
  }

  .cs-step-title {
    font-size: var(--text-body);    /* 15px */
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: 0.25rem;
  }

  .cs-step-desc {
    font-size: var(--text-base);    /* 14px */
    color: var(--ink-2);
    line-height: 1.6;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  .cs-insights { display: flex; flex-direction: column; gap: 1.25rem; }
  .cs-insight { display: grid; grid-template-columns: 2rem 1fr; gap: 0 1rem; align-items: start; }
  .cs-insight-num { font-size: var(--text-xs); font-weight: 800; color: var(--accent); padding-top: 0.15em; font-variant-numeric: tabular-nums; }
  .cs-insight-title { font-size: var(--text-body); font-weight: 700; color: var(--ink); margin-bottom: 0.3rem; letter-spacing: -0.01em; }
  .cs-insight-desc { font-size: var(--text-caption); color: var(--ink-3); line-height: 1.7; }

  /* Results */
  .cs-results {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 480px) {
    .cs-results { grid-template-columns: 1fr; }
  }

  .cs-result {
    background: var(--bg);
    padding: 1.25rem;
    transition: background var(--dur-fast) var(--ease);
    min-width: 0;
  }

  .cs-result:hover { background: var(--canvas); }

  .cs-result-label {
    font-size: var(--text-xs);      /* 11px */
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .cs-result-val {
    font-size: var(--text-body);    /* 15px */
    font-weight: 500;
    color: var(--ink);
    line-height: 1.5;
    letter-spacing: -0.01em;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  /* Contribution */
  .cs-contrib { margin-top: 0; }

  .cc-row {
    display: flex;
    gap: 2rem;
    padding: 1rem 0;
    align-items: baseline;
  }

  .cc-key {
    font-size: var(--text-xs);      /* 11px */
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    min-width: 4rem;
    padding-top: 0.1em;
  }

  .cc-val {
    font-size: var(--text-body);    /* 15px */
    color: var(--ink-2);
    line-height: 1.6;
    min-width: 0;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  @media (max-width: 520px) {
    .cs-tag-row {
      display: grid;
      grid-template-columns: repeat(2, max-content);
      align-items: start;
      column-gap: 0.375rem;
      row-gap: 0.375rem;
    }

    .cs-stat-inner {
      flex-wrap: wrap;
      row-gap: 0.5rem;
    }

    .cs-step {
      gap: 1rem;
    }
  }

  @media (max-width: 860px) {
    .cs {
      padding-top: 0;
    }

    .cs-title {
      font-size: 1.375rem;
      line-height: 1.22;
      word-break: normal;
      overflow-wrap: anywhere;
    }

    .cs-title,
    .cs-sub,
    .cs-prose,
    .cs-step-desc,
    .cs-result-val,
    .cc-val {
      word-break: keep-all;
      overflow-wrap: anywhere;
    }

    .cs-results {
      grid-template-columns: 1fr;
    }
  }

  /* Screenshots */
  .cs-shot-inner {
    display: block;
    position: relative;
    overflow: hidden;
  }

  .cs-shot-inner img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--dur) var(--ease);
  }

  .cs-shot-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 1.125rem 1rem;
    background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.62) 100%);
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease);
  }

  .cs-shot-overlay span {
    font-size: var(--text-caption);
    color: #fff;
    line-height: 1.5;
    letter-spacing: 0.01em;
  }

  /* Next project */
  .cs-next {
    border-top: 1px solid var(--line);
    padding: 2.75rem 0 4rem;
  }

  .cs-next-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.125rem 0;
    border-top: 1px solid var(--line);
